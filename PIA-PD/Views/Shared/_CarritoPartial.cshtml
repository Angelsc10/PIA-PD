@model List<PIA_PD.Models.CarritoItem>
@{
    decimal subtotal = Model?.Sum(i => i.Precio * i.Cantidad) ?? 0;
    string cupon = ViewBag.CuponAplicado as string;
    int porcentaje = ViewBag.DescuentoPorcentaje != null ? (int)ViewBag.DescuentoPorcentaje : 0;
    decimal descuento = (subtotal * porcentaje) / 100m;
    decimal total = subtotal - descuento;
}

<input type="hidden" id="cartItemCount" value="@(Model?.Sum(i => i.Cantidad) ?? 0)" />

<div class="d-flex flex-column h-100">
    <div class="flex-grow-1 overflow-auto pe-2" style="min-height: 0;">
        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5" style="color: var(--azul-elegante);">
                <i class="bi bi-cart-x display-1"></i>
                <p class="mt-3 fw-bold">Tu carrito está vacío.</p>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="d-flex align-items-center mb-3 p-2 bg-white rounded border shadow-sm">
                    <img src="@item.PortadaUrl" class="cart-img shadow-sm me-3" style="width: 50px; height: 70px; object-fit: cover; border-radius: 6px;">
                    <div class="flex-grow-1">
                        <h6 class="mb-0 fw-bold text-truncate" style="max-width: 150px; color: var(--azul-profundo);">@item.Titulo</h6>
                        <small class="fw-bold" style="color: var(--azul-elegante);">$@item.Precio.ToString("0.00")</small>
                        <div class="d-flex align-items-center mt-1">
                            <button class="btn btn-sm py-0 px-2 rounded-circle" style="border: 1px solid var(--azul-elegante); color: var(--azul-elegante);" onclick="modQty('@item.LibroId', -1)">-</button>
                            <span class="mx-2 fw-bold">@item.Cantidad</span>
                            <button class="btn btn-sm py-0 px-2 rounded-circle" style="border: 1px solid var(--azul-elegante); color: var(--azul-elegante);" onclick="modQty('@item.LibroId', 1)">+</button>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <div class="border-top pt-3 mt-3 shadow-lg p-3" style="margin: 0 -1rem -1rem -1rem; background: var(--azul-claro);">

        @if (Model != null && Model.Any())
        {
            <div class="mb-3">
                @if (string.IsNullOrEmpty(cupon))
                {
                    <div class="input-group input-group-sm mb-2 shadow-sm">
                        <span class="input-group-text bg-white" style="color: var(--azul-profundo);"><i class="bi bi-ticket-perforated"></i></span>
                        <input type="text" id="inputCupon" class="form-control border-start-0" placeholder="Código de descuento" onkeypress="if(event.key === 'Enter') aplicarCupon()">
                        <button class="btn fw-bold px-3" style="background: var(--azul-profundo); color: white;" onclick="aplicarCupon()">Aplicar</button>
                    </div>
                }
                else
                {
                    <div class="alert p-2 mb-2 d-flex justify-content-between align-items-center small shadow-sm" style="background: white; border: 1px solid var(--azul-elegante); color: var(--azul-profundo);">
                        <span><i class="bi bi-check-circle-fill me-1"></i> Cupón <strong>@cupon</strong> (-@porcentaje%)</span>
                        <button class="btn btn-sm py-0 px-2 rounded-circle shadow-sm" style="background: var(--rojo-soft); color: white;" onclick="quitarCupon()" title="Quitar cupón"><i class="bi bi-x fs-6"></i></button>
                    </div>
                }
            </div>
        }

        <div class="d-flex justify-content-between small px-2 mb-1" style="color: var(--azul-profundo);">
            <span>Subtotal:</span>
            <span>$@subtotal.ToString("0.00")</span>
        </div>
        @if (descuento > 0)
        {
            <div class="d-flex justify-content-between small px-2 mb-1 fw-bold" style="color: var(--rojo-soft);">
                <span>Descuento (-@porcentaje%):</span>
                <span>-$@descuento.ToString("0.00")</span>
            </div>
        }
        <div class="d-flex justify-content-between fs-5 fw-bold mb-3 px-2 mt-2 border-top pt-2" style="color: var(--azul-profundo);">
            <span>Total a pagar:</span>
            <span>$@total.ToString("0.00")</span>
        </div>

        @if (User.Identity.IsAuthenticated)
        {
            <a href="/Carrito/Checkout" class="btn btn-lg w-100 rounded-pill shadow-sm @(Model?.Any() == true ? "" : "disabled")" style="background: var(--azul-profundo); color: white;">
                Finalizar Compra <i class="bi bi-shield-lock ms-2"></i>
            </a>
        }
        else
        {
            <a href="/Account/Login" class="btn btn-lg w-100 rounded-pill shadow-sm fw-bold @(Model?.Any() == true ? "" : "disabled")" style="background: var(--azul-elegante); color: white;">
                Iniciar Sesión para Pagar <i class="bi bi-person-circle ms-2"></i>
            </a>
        }
    </div>
</div>