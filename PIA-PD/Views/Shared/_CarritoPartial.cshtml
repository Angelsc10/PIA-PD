@model List<PIA_PD.Models.CarritoItem>
@{
    decimal total = Model.Sum(i => i.Precio * i.Cantidad);
}

<input type="hidden" id="cartItemCount" value="@Model.Sum(i => i.Cantidad)" />

<div class="flex-grow-1 overflow-auto pe-2">
    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-cart-x display-1"></i>
            <p class="mt-3 fw-bold">Tu carrito está vacío.</p>
        </div>
    }
    else
    {
        @foreach (var item in Model)
        {
            <div class="d-flex align-items-center mb-3 p-2 bg-white rounded border shadow-sm">
                <img src="@item.PortadaUrl" class="cart-img shadow-sm me-3">
                <div class="flex-grow-1">
                    <h6 class="mb-0 fw-bold text-truncate" style="max-width: 150px;">@item.Titulo</h6>
                    <small class="text-primary fw-bold">$@item.Precio.ToString("0.00")</small>
                    <div class="d-flex align-items-center mt-1">
                        <button class="btn btn-sm btn-outline-secondary py-0 px-2" onclick="modQty('@item.LibroId', -1)">-</button>
                        <span class="mx-2 fw-bold">@item.Cantidad</span>
                        <button class="btn btn-sm btn-outline-secondary py-0 px-2" onclick="modQty('@item.LibroId', 1)">+</button>
                    </div>
                </div>
                <div class="text-end ms-2">
                    <button class="btn btn-link text-danger p-0" onclick="modQty('@item.LibroId', -@item.Cantidad)" title="Eliminar">
                        <i class="bi bi-trash3"></i>
                    </button>
                </div>
            </div>
        }
    }
</div>

<div class="border-top pt-3 mt-3">
    <div class="d-flex justify-content-between fs-5 fw-bold mb-3">
        <span>Total a pagar:</span>
        <span class="text-primary">$@total.ToString("0.00")</span>
    </div>

    @if (User.Identity.IsAuthenticated)
    {
        <a href="/Carrito/Checkout" class="btn btn-success btn-lg w-100 rounded-pill shadow-sm @(Model.Any() ? "" : "disabled")">
            Proceder al Pago <i class="bi bi-shield-lock ms-2"></i>
        </a>
    }
    else
    {
        <a href="/Account/Login" class="btn btn-warning btn-lg w-100 rounded-pill shadow-sm fw-bold @(Model.Any() ? "" : "disabled")">
            Inicia sesión para pagar <i class="bi bi-person-circle ms-2"></i>
        </a>
    }
</div>

<script>
    // Función local para los botones +/-
    function modQty(id, cambio) {
        $.post('/Carrito/ActualizarCantidad', { id: id, cambio: cambio }, function() {
            refreshCart();
        });
    }
</script>