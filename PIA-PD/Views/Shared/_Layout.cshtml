@using Microsoft.AspNetCore.Http
@using PIA_PD.Extensions
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - El Rincón del Libro</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        :root {
            --azul-profundo: #0B2B40; /* Color exacto unificado */
            --azul-marino: #144A66;
            --azul-elegante: #334155;
            --oro-suave: #D4AF37;
        }

        body {
            font-family: 'Inter', sans-serif;
        }

        .navbar-premium {
            background: linear-gradient(90deg, var(--azul-profundo), var(--azul-marino));
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        .hover-lift:hover {
            transform: translateY(-2px);
            transition: transform 0.2s;
        }

        /* Chatbot estilos */
        .chat-container {
            height: 250px;
            overflow-y: auto;
            background-color: #f8f9fa;
            padding: 10px;
        }

        .msg-bot-custom {
            background-color: white;
            border-left: 4px solid var(--azul-profundo);
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark navbar-premium sticky-top py-3">
            <div class="container-fluid px-4">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-book-half text-warning fs-3"></i>
                    <span>El Rincón del Libro</span>
                </a>
                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse" id="navbarMain">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4">
                        <li class="nav-item"><a class="nav-link fs-6" asp-controller="Home" asp-action="Index">Catálogo</a></li>
                    </ul>
                    <ul class="navbar-nav align-items-center gap-3">
                        @if (!User.IsInRole("Admin") && !User.IsInRole("Empleado"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white position-relative hover-lift" asp-controller="Deseos" asp-action="Index" title="Lista de Deseos">
                                    <i class="bi bi-heart fs-5"></i>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white position-relative hover-lift" href="javascript:void(0)" onclick="openCart()">
                                    <i class="bi bi-bag fs-5"></i>
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-2 border-dark" id="cartBadge" style="font-size: 0.65rem;">0</span>
                                </a>
                            </li>
                        }
                        <div class="vr d-none d-lg-block bg-white opacity-25 mx-2"></div>
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" data-bs-toggle="dropdown">
                                    <div class="bg-light text-dark rounded-circle d-flex justify-content-center align-items-center fw-bold" style="width: 32px; height: 32px;">
                                        @User.Identity.Name.Substring(0, 1).ToUpper()
                                    </div>
                                    <span class="fw-medium">@User.Identity.Name</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 mt-2 rounded-3">
                                    @if (!User.IsInRole("Admin") && !User.IsInRole("Empleado"))
                                    {
                                        <li><a class="dropdown-item py-2" asp-controller="Pedidos" asp-action="Index"><i class="bi bi-box-seam me-2 text-muted"></i>Mis Pedidos</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                    }
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post">
                                            <button type="submit" class="dropdown-item py-2 text-danger fw-medium"><i class="bi bi-box-arrow-right me-2"></i>Cerrar Sesión</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login">Ingresar</a></li>
                            <li class="nav-item"><a class="btn btn-outline-light rounded-pill px-4 fw-bold" asp-controller="Account" asp-action="Register">Regístrate</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="pb-5 flex-grow-1">@RenderBody()</main>

    <footer class="text-white pt-5 pb-4 mt-auto" style="background-color: var(--azul-profundo);">
        <div class="container text-center text-md-start">
            <div class="row">
                <div class="col-md-4 mt-3">
                    <h5 class="text-uppercase mb-3 fw-bold" style="color: var(--oro-suave);"><i class="bi bi-book-half me-2"></i>El Rincón del Libro</h5>
                    <p class="text-light opacity-75">Tu destino ideal para encontrar las mejores historias.</p>
                </div>
                <div class="col-md-4 mt-3 text-md-center">
                    <h5 class="text-uppercase mb-3 fw-bold" style="color: var(--oro-suave);">Contacto</h5>
                    <p class="text-light opacity-75 mb-1"><i class="bi bi-house-door-fill me-2"></i> UANL, San Nicolás</p>
                    <p class="text-light opacity-75 mb-0"><i class="bi bi-envelope-fill me-2"></i> contacto@rincondellibro.com</p>
                </div>
                <div class="col-md-4 mt-3 text-md-end">
                    <h5 class="text-uppercase mb-3 fw-bold" style="color: var(--oro-suave);">Aviso Legal</h5>
                    <p class="text-light opacity-75 mb-1 small">© 2026 PIA_PD. Todos los derechos reservados.</p>
                    <p class="text-light opacity-75 small">Prohibida la reproducción total o parcial.</p>
                </div>
            </div>
        </div>
    </footer>

    <div class="offcanvas offcanvas-end shadow" tabindex="-1" id="cartSidebar" style="width: 400px;">
        <div class="offcanvas-header bg-dark text-white"><h5 class="offcanvas-title fw-bold">Mi Carrito</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button></div>
        <div class="offcanvas-body" id="cartBody"></div>
    </div>

    <div id="botWindow" class="card shadow position-fixed border-0" style="bottom: 90px; right: 20px; width: 320px; z-index: 1050; display: none; border-radius: 12px; overflow: hidden;">
        <div class="card-header text-white d-flex justify-content-between align-items-center" style="background-color: var(--azul-profundo);">
            <h6 class="mb-0"><i class="bi bi-robot me-2"></i>Asistente</h6>
            <button type="button" class="btn-close btn-close-white" onclick="toggleBot()"></button>
        </div>
        <div class="card-body chat-container" id="botChatBody">
            <div class="text-start mb-2"><span class="badge msg-bot-custom p-2 text-dark text-wrap">¡Hola! ¿En qué te ayudo? 📚</span></div>
        </div>
        <div class="card-footer p-2 bg-white border-top">
            <div class="input-group">
                <input type="text" id="botInput" class="form-control" placeholder="Escribe..." onkeypress="if(event.key === 'Enter') sendBotMessage()">
                <button class="btn btn-primary" onclick="sendBotMessage()"><i class="bi bi-send"></i></button>
            </div>
        </div>
    </div>

    <button id="botBtnToggle" class="btn btn-primary rounded-circle position-fixed shadow d-flex justify-content-center align-items-center" style="bottom: 20px; right: 20px; width: 60px; height: 60px; z-index: 1050;" onclick="toggleBot()">
        <i class="bi bi-chat-dots fs-3"></i>
    </button>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const cartOff = document.getElementById('cartSidebar') ? new bootstrap.Offcanvas('#cartSidebar') : null;
        function openCart() { refreshCart(); if(cartOff) cartOff.show(); }
        function refreshCart() { $.get('/Carrito/GetCarritoPartial', function(data) { $('#cartBody').html(data); $('#cartBadge').text($('#cartItemCount').val() || 0); }); }
        function toggleBot() { $('#botWindow').fadeToggle('fast'); }
        function sendBotMessage() {
            const input = $('#botInput'); const msg = input.val().trim(); if (!msg) return;
            $('#botChatBody').append(`<div class="text-end mb-2"><span class="badge bg-primary p-2">${msg}</span></div>`); input.val('');
            $.get('/Chatbot/Preguntar', { mensaje: msg }, function(res) {
                $('#botChatBody').append(`<div class="text-start mb-2"><span class="badge msg-bot-custom p-2 text-dark text-wrap">${res.respuesta}</span></div>`);
                document.getElementById('botChatBody').scrollTop = document.getElementById('botChatBody').scrollHeight;
            });
        }
        $(document).ready(refreshCart);
    </script>
</body>
</html>