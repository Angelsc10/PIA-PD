@using Microsoft.AspNetCore.Http
@using PIA_PD.Extensions
@using PIA_PD.Models
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - El Rincón del Libro</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">El Rincón del Libro</a>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Inicio</a></li>
                        @if (User.Identity.IsAuthenticated && (User.IsInRole("Admin") || User.IsInRole("Empleado")))
                        {
                            <li class="nav-item"><a class="nav-link text-warning fw-bold" asp-controller="Admin" asp-action="Index">Panel Staff</a></li>
                        }
                    </ul>
                    <ul class="navbar-nav align-items-center">
                        @{
                            var carritoActual = HttpContextAccessor.HttpContext?.Session?.Get<List<CarritoItem>>("MiCarrito") ?? new List<CarritoItem>();
                            int totalItems = carritoActual.Sum(i => i.Cantidad);
                        }
                        <li class="nav-item"><a class="nav-link text-white fw-bold me-3" asp-controller="Carrito" asp-action="Index"><i class="bi bi-cart3"></i> (@totalItems)</a></li>
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item"><span class="nav-link text-light me-2">@User.Identity.Name</span></li>
                            <li class="nav-item"><form asp-controller="Account" asp-action="Logout" method="post"><button type="submit" class="btn btn-link text-danger fw-bold shadow-none border-0">Salir</button></form></li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link btn btn-outline-light px-3 rounded-pill" asp-controller="Account" asp-action="Login">Entrar</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="pb-3 flex-grow-1">@RenderBody()</main>

    <button class="btn btn-primary rounded-circle shadow-lg position-fixed d-flex justify-content-center align-items-center" type="button" data-bs-toggle="offcanvas" data-bs-target="#chatbotOffcanvas" style="bottom: 30px; right: 30px; width: 65px; height: 65px; z-index: 1000;"><i class="bi bi-robot fs-2"></i></button>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // Lógica de Notificaciones Elegantes
        $(document).ready(function() {
            var exito = '@TempData["Exito"]';
            var error = '@TempData["Error"]';

            if (exito) {
                Swal.fire({ icon: 'success', title: '¡Éxito!', text: exito, timer: 2500, showConfirmButton: false });
            }
            if (error) {
                Swal.fire({ icon: 'error', title: 'Atención', text: error });
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>