@using Microsoft.AspNetCore.Http
@using PIA_PD.Extensions
@inject IHttpContextAccessor HttpContextAccessor

@{
    var action = ViewContext.RouteData.Values["action"]?.ToString();
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();

    bool esAdminOEmpleado = User.IsInRole("Admin") || User.IsInRole("Empleado");
    bool esPaginaAuth = controller == "Account" && (action == "Login" || action == "Register");
    bool esPaginaInicio = controller == "Home" && action == "Index";

    // El chatbot solo se muestra si es la página de inicio, NO es admin/empleado y NO es página de auth
    bool mostrarChatbot = esPaginaInicio && !esAdminOEmpleado && !esPaginaAuth;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - El Rincón del Libro</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        .filter-white {
            filter: brightness(0) invert(1);
        }

        .v-align-middle {
            vertical-align: middle;
        }

        .hover-lift {
            transition: all 0.3s ease;
        }

            .hover-lift:hover {
                transform: translateY(-3px);
                color: var(--oro-suave) !important;
                opacity: 1 !important;
            }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark sticky-top py-3">
            <div class="container-fluid px-4">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-book-half fs-3" style="color: var(--oro-suave);"></i>
                    <span>El Rincón del Libro</span>
                </a>
                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse" id="navbarMain">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4">
                        <li class="nav-item">
                            <a class="nav-link fs-6 text-white" asp-controller="Home" asp-action="Index">Catálogo</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav align-items-center gap-3">
                        @if (!esAdminOEmpleado)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white position-relative hover-lift" asp-controller="Deseos" asp-action="Index" title="Lista de Deseos">
                                    <i class="bi bi-heart fs-5"></i>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white position-relative hover-lift" href="javascript:void(0)" onclick="openCart()">
                                    <i class="bi bi-bag fs-5"></i>
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill" id="cartBadge" style="font-size: 0.65rem;">0</span>
                                </a>
                            </li>
                        }

                        <div class="vr d-none d-lg-block bg-white opacity-25 mx-2"></div>

                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center gap-2 text-white" href="#" data-bs-toggle="dropdown">
                                    <div class="rounded-circle d-flex justify-content-center align-items-center fw-bold"
                                         style="width: 32px; height: 32px; background-color: var(--azul-claro); color: var(--azul-profundo);">
                                        @User.Identity.Name[..1].ToUpper()
                                    </div>
                                    <span class="fw-medium">@User.Identity.Name</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 mt-2">
                                    @if (!esAdminOEmpleado)
                                    {
                                        <li><a class="dropdown-item py-2" asp-controller="Pedidos" asp-action="Index"><i class="bi bi-box-seam me-2 text-muted"></i>Mis Pedidos</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                    }
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post">
                                            <button type="submit" class="dropdown-item py-2 text-danger fw-medium"><i class="bi bi-box-arrow-right me-2"></i>Cerrar Sesión</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link text-white" asp-controller="Account" asp-action="Login">Ingresar</a></li>
                            <li class="nav-item"><a class="btn btn-outline-light rounded-pill px-4 fw-bold" asp-controller="Account" asp-action="Register">Regístrate</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="pb-5 flex-grow-1">
        @RenderBody()
    </main>

    <footer class="text-white py-5 mt-auto" style="background: linear-gradient(135deg, var(--azul-profundo) 0%, var(--azul-marino) 100%); border-top: 3px solid var(--oro-suave);">
        <div class="container">
            <div class="row g-4 align-items-center">
                <div class="col-lg-6 col-md-12 text-center text-lg-start">
                    <h5 class="text-uppercase mb-3 fw-bold d-flex align-items-center justify-content-center justify-content-lg-start gap-2" style="font-family: 'Playfair Display', serif;">
                        <i class="bi bi-book-half" style="color: var(--oro-suave);"></i>
                        <span style="background: linear-gradient(120deg, #FFFFFF, #C5DEE8); -webkit-background-clip: text; background-clip: text; color: transparent;">
                            El Rincón del Libro
                        </span>
                    </h5>
                    <p class="small opacity-75 mb-0" style="max-width: 450px; line-height: 1.6;">
                        Tu destino literario premium. Nos apasiona conectar historias con lectores, ofreciendo una curaduría excepcional de obras para mentes curiosas.
                    </p>
                    <div class="d-flex gap-3 mt-4 justify-content-center justify-content-lg-start">
                        <a href="#" class="text-white opacity-75 hover-lift"><i class="bi bi-facebook fs-5"></i></a>
                        <a href="#" class="text-white opacity-75 hover-lift"><i class="bi bi-instagram fs-5"></i></a>
                        <a href="#" class="text-white opacity-75 hover-lift"><i class="bi bi-twitter-x fs-5"></i></a>
                    </div>
                </div>

                <div class="col-lg-6 col-md-12 text-center text-lg-end">
                    <h6 class="text-uppercase mb-3 fw-bold" style="font-family: 'Playfair Display', serif; color: var(--oro-suave);">Contacto Directo</h6>
                    <div class="small opacity-75">
                        <p class="mb-2"><i class="bi bi-geo-alt-fill me-2" style="color: var(--oro-suave);"></i> Av. Universidad, San Nicolás de los Garza, NL</p>
                        <p class="mb-2"><i class="bi bi-envelope-fill me-2" style="color: var(--oro-suave);"></i> contacto@rincondellibro.com</p>
                        <p class="mb-0"><i class="bi bi-telephone-fill me-2" style="color: var(--oro-suave);"></i> +52 (81) 1234 5678</p>
                    </div>
                </div>
            </div>

            <hr class="my-4 opacity-25">

            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    <p class="small mb-0 opacity-50">
                        &copy; 2026 El Rincón del Libro. Todos los derechos reservados.
                    </p>
                </div>
                <div class="col-md-6 text-center text-md-end mt-3 mt-md-0">
                    <span class="small opacity-50 me-3">Pagos Seguros:</span>
                    <img src="https://upload.wikimedia.org/wikipedia/commons/b/b5/PayPal.svg" alt="PayPal" height="18" class="me-3 opacity-75 filter-white">
                    <i class="bi bi-credit-card-2-back fs-4 opacity-75 v-align-middle"></i>
                </div>
            </div>
        </div>
    </footer>

    <div class="offcanvas offcanvas-end offcanvas-custom shadow" tabindex="-1" id="cartSidebar">
        <div class="offcanvas-header text-white">
            <h5 class="offcanvas-title fw-bold" style="font-family: 'Playfair Display', serif;">Mi Carrito</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
        </div>
        <div class="offcanvas-body" id="cartBody"></div>
    </div>

    @if (mostrarChatbot)
    {
        <div id="botWindow" class="card shadow position-fixed border-0" style="bottom: 90px; right: 20px; width: 350px; z-index: 1050; display: none; border-radius: 20px !important;">
            <div class="card-header text-white d-flex justify-content-between align-items-center rounded-top"
                 style="background: linear-gradient(135deg, var(--azul-elegante), var(--azul-marino)); border:none;">
                <h6 class="mb-0 fw-bold"><i class="bi bi-robot me-2"></i>Asistente Virtual</h6>
                <button type="button" class="btn-close btn-close-white" onclick="toggleBot()"></button>
            </div>
            <div class="card-body" id="botChatBody" style="height: 350px; overflow-y: auto; background-color: var(--blanco-humo);">
                <div class="text-start mb-3">
                    <span class="badge text-wrap text-start p-2 fs-6 shadow-sm"
                          style="font-weight: 500; background-color: var(--azul-claro); color: var(--azul-profundo); border-radius: 15px;">
                        ¡Hola! Soy tu asistente de El Rincón del Libro 📚 ¿En qué te puedo ayudar hoy?
                    </span>
                </div>
            </div>
            <div class="card-footer p-2 bg-white rounded-bottom border-top">
                <div class="input-group">
                    <input type="text" id="botInput" class="form-control" placeholder="Escribe tu mensaje..." onkeypress="if(event.key === 'Enter') sendBotMessage()">
                    <button class="btn btn-primary" onclick="sendBotMessage()"><i class="bi bi-send"></i></button>
                </div>
            </div>
        </div>

        <button id="botBtnToggle" class="btn btn-float-chat rounded-circle position-fixed shadow d-flex justify-content-center align-items-center text-white"
                style="bottom: 20px; right: 20px; width: 60px; height: 60px; z-index: 1050; border:none;" onclick="toggleBot()">
            <i class="bi bi-chat-dots fs-3"></i>
        </button>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // Elementos Cacheables para JavaScript
        const $cartBody = $('#cartBody');
        const $cartBadge = $('#cartBadge');
        const $botChatBody = $('#botChatBody');
        const $botWindow = $('#botWindow');
        const $botBtnToggle = $('#botBtnToggle');

        const cartOff = document.getElementById('cartSidebar') ? new bootstrap.Offcanvas('#cartSidebar') : null;

        function openCart() { refreshCart(); cartOff?.show(); }

        function refreshCart() {
            $.get('/Carrito/GetCarritoPartial', function(data) {
                $cartBody.html(data);
                $cartBadge.text($('#cartItemCount').val() || 0);
            });
        }

        function aplicarCupon() {
            let cod = $('#inputCupon').val().trim();
            if(!cod) return;
            $.post('/Carrito/AplicarCupon', { codigo: cod }, function(res) {
                if(res.success) {
                    refreshCart();
                    Swal.fire({ icon: 'success', title: '¡Éxito!', text: res.message, toast: true, position: 'top-end', timer: 2500, showConfirmButton: false });
                } else {
                    Swal.fire({ icon: 'error', title: 'Cupón inválido', text: res.message, confirmButtonColor: '#0B2B40' });
                }
            });
        }

        function quitarCupon() {
            $.post('/Carrito/QuitarCupon', function() { refreshCart(); });
        }

        function addToCart(id, titulo) {
            let btnHome = $('button').filter(function() {
                let oc = $(this).attr('onclick');
                return oc && oc.includes(`addToCart('${id}'`);
            });
            btnHome.css('pointer-events', 'none');
            $.post('/Carrito/Agregar', { id: id, cantidad: 1 }, function (res) {
                if (res.success) {
                    refreshCart();
                    Swal.fire({ icon: 'success', title: '¡Añadido!', text: titulo + " se agregó al carrito.", toast: true, position: 'top-end', timer: 2000, showConfirmButton: false });
                    btnHome.css('pointer-events', 'auto');
                } else {
                    Swal.fire({ icon: 'info', title: 'Sin Existencias', text: res.message, confirmButtonColor: '#144A66' });
                    btnHome.prop('disabled', true).addClass('disabled text-muted').html('<i class="bi bi-x-circle-fill fs-5"></i>');
                }
            });
        }

        function modQty(id, cambio) {
            let btnTrigger = $('button').filter(function() {
                let oc = $(this).attr('onclick');
                return oc && oc.includes(`modQty('${id}', ${cambio})`);
            });
            btnTrigger.css('pointer-events', 'none');
            $.post('/Carrito/ActualizarCantidad', { id: id, cambio: cambio }, function(res) {
                if (res.success) {
                    refreshCart();
                } else {
                    Swal.fire({ icon: 'warning', title: 'Límite Alcanzado', text: 'Máximo disponible alcanzado.', confirmButtonColor: '#E74C3C' });
                }
                btnTrigger.css('pointer-events', 'auto');
            });
        }

        function toggleWishlist(id, titulo, precio, portadaUrl, btnElement) {
            $.post('/Deseos/AlternarAjax', { id: id, titulo: titulo, precio: precio, portadaUrl: portadaUrl }, function(res) {
                if (res.success) {
                    let icon = $(btnElement).find('i');
                    if (res.agregado) {
                        icon.removeClass('bi-heart text-dark').addClass('bi-heart-fill text-danger');
                    } else {
                        icon.removeClass('bi-heart-fill text-danger').addClass('bi-heart text-dark');
                    }
                    Swal.fire({ icon: 'success', title: res.agregado ? '¡Agregado!' : 'Eliminado', text: res.message, toast: true, position: 'top-end', timer: 2000, showConfirmButton: false });
                }
            }).fail(function(xhr) {
                if (xhr.status === 401) window.location.href = '/Account/Login';
            });
        }

        function toggleBot() {
            if ($botWindow.length) {
                $botWindow.fadeToggle('fast');
                let icon = $botBtnToggle.find('i');
                if (icon.hasClass('bi-chat-dots')) {
                    icon.removeClass('bi-chat-dots').addClass('bi-x-lg');
                    $botBtnToggle.css('transform', 'rotate(90deg)');
                } else {
                    icon.removeClass('bi-x-lg').addClass('bi-chat-dots');
                    $botBtnToggle.css('transform', 'rotate(0deg)');
                }
            }
        }

        function sendBotMessage() {
            const input = $('#botInput');
            const msg = input.val().trim();
            if (!msg) return;

            $botChatBody.append(`<div class="text-end mb-3"><span class="badge p-2 fs-6 shadow-sm" style="background: linear-gradient(135deg, var(--azul-elegante), var(--azul-marino)); color:white; border-radius:15px 15px 0 15px;">${msg}</span></div>`);
            input.val('');

            const typingId = 'typing-' + Date.now();
            $botChatBody.append(`<div class="text-start mb-3" id="${typingId}"><span class="badge bg-light text-dark p-2 fs-6 shadow-sm"><i class="bi bi-three-dots"></i></span></div>`);

            $.get('/Chatbot/Preguntar', { mensaje: msg }, function(res) {
                $('#' + typingId).remove();
                $botChatBody.append(`<div class="text-start mb-3"><span class="badge text-wrap text-start p-2 fs-6 shadow-sm" style="background-color: var(--azul-claro); color: var(--azul-profundo); border-radius: 15px 15px 15px 0;">${res.respuesta}</span></div>`);
                const body = document.getElementById('botChatBody');
                if(body) body.scrollTop = body.scrollHeight;
            });
        }

        $(document).ready(refreshCart);
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>