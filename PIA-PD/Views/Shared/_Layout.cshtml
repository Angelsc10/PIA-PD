@using Microsoft.AspNetCore.Http
@using PIA_PD.Extensions
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>@ViewData["Title"] - El Rincón del Libro</title>

    <!-- Tipografía elegante (Google Fonts) -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,500&display=swap" rel="stylesheet">

    <!-- Bootstrap + Iconos -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />

    <!-- Estilos personalizados elegantes -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark mb-3 shadow sticky-top">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-controller="@(User.IsInRole("Admin") || User.IsInRole("Empleado") ? "Admin" : "Home")" asp-action="Index">
                    <i class="bi bi-book-half me-2"></i>El Rincón del Libro
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-label="Menú">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 gap-1">
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item"><a class="nav-link text-warning fw-semibold ms-2" asp-controller="Admin" asp-action="Index"><i class="bi bi-shield-lock-fill me-1"></i>MODO ADMINISTRADOR</a></li>
                        }
                        else if (User.IsInRole("Empleado"))
                        {
                            <li class="nav-item"><a class="nav-link text-info fw-semibold ms-2" asp-controller="Admin" asp-action="Index"><i class="bi bi-person-badge me-1"></i>MODO EMPLEADO</a></li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index"><i class="bi bi-grid-3x3-gap-fill me-1"></i>Catálogo</a></li>
                        }
                    </ul>
                    <ul class="navbar-nav align-items-center gap-1">
                        @if (!User.IsInRole("Admin") && !User.IsInRole("Empleado"))
                        {
                            @if (User.Identity.IsAuthenticated)
                            {
                                <li class="nav-item me-1">
                                    <a class="nav-link" asp-controller="Deseos" asp-action="Index" title="Mis Favoritos">
                                        <i class="bi bi-heart-fill fs-5 align-middle"></i>
                                    </a>
                                </li>
                            }
                            <li class="nav-item me-2 cart-icon-container">
                                <a class="nav-link text-white position-relative" href="javascript:void(0)" onclick="openCart()">
                                    <i class="bi bi-cart3 fs-4"></i>
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill" id="cartBadge">0</span>
                                </a>
                            </li>
                        }

                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center gap-2 rounded-pill px-3 py-1" href="#" id="userDrop" data-bs-toggle="dropdown" style="background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.18);">
                                    <i class="bi bi-person-circle"></i> @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                                    @if (!User.IsInRole("Admin") && !User.IsInRole("Empleado"))
                                    {
                                        <li><a class="dropdown-item py-2" asp-controller="Pedidos" asp-action="Index"><i class="bi bi-receipt me-2"></i>Mis Pedidos</a></li>
                                        <li><hr class="dropdown-divider my-1"></li>
                                    }
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post">
                                            <button type="submit" class="dropdown-item fw-semibold text-danger">
                                                <i class="bi bi-box-arrow-right me-2"></i>Cerrar Sesión
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item me-1"><a class="nav-link btn btn-outline-light px-4 rounded-pill" asp-controller="Account" asp-action="Login"><i class="bi bi-key me-1"></i>Iniciar Sesión</a></li>
                            <li class="nav-item"><a class="nav-link btn btn-primary px-4 rounded-pill text-white fw-bold shadow-sm" asp-controller="Account" asp-action="Register"><i class="bi bi-person-plus me-1"></i>Crear Cuenta</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="pb-3 flex-grow-1">
        <div class="container-fluid px-3 px-md-4 px-lg-5">
            @RenderBody()
        </div>
    </main>

    @{
        var isCheckout = ViewContext.RouteData.Values["Action"]?.ToString() == "Checkout";
    }

    @if (!User.IsInRole("Admin") && !User.IsInRole("Empleado"))
    {
        @if (!isCheckout)
        {
            <button class="btn btn-primary rounded-circle shadow-lg position-fixed d-flex justify-content-center align-items-center btn-float-chat" type="button" onclick="openChat()" style="bottom: 30px; right: 30px; width: 65px; height: 65px; z-index: 1000; border: none;">
                <i class="bi bi-robot fs-2"></i>
            </button>

            <div class="offcanvas offcanvas-end offcanvas-custom shadow" tabindex="-1" id="chatSidebar">
                <div class="offcanvas-header">
                    <h5 class="offcanvas-title fw-bold"><i class="bi bi-robot me-2"></i>Asistente Librero</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Cerrar"></button>
                </div>
                <div class="offcanvas-body d-flex flex-column bg-light">
                    <div id="chatBox" class="flex-grow-1 overflow-auto p-3 mb-3 bg-white rounded border" style="max-height: 70vh;"></div>
                    <div class="input-group shadow-sm">
                        <input type="text" id="chatInput" class="form-control border-0 px-3" placeholder="¿Qué libro buscas?" onkeypress="handleEnter(event)" autocomplete="off">
                        <button class="btn btn-primary" onclick="sendMsg()"><i class="bi bi-send"></i></button>
                    </div>
                </div>
            </div>
        }

        <div class="offcanvas offcanvas-start offcanvas-custom shadow" tabindex="-1" id="cartSidebar">
            <div class="offcanvas-header">
                <h5 class="offcanvas-title fw-bold"><i class="bi bi-cart3 me-2"></i>Carrito de Compras</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Cerrar"></button>
            </div>
            <div class="offcanvas-body d-flex flex-column" id="cartBody">
            </div>
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // ============================================
        // CARRITO Y CHATBOT - LÓGICA ORIGINAL
        // ============================================
        const cartOff = document.getElementById('cartSidebar') ? new bootstrap.Offcanvas('#cartSidebar') : null;
        const chatOff = document.getElementById('chatSidebar') ? new bootstrap.Offcanvas('#chatSidebar') : null;

        function openCart() { if(chatOff) chatOff.hide(); refreshCart(); if(cartOff) cartOff.show(); }
        function openChat() { if(cartOff) cartOff.hide(); if(chatOff) chatOff.show(); }

        function refreshCart() {
            if(!document.getElementById('cartBody')) return;
            $.get('/Carrito/GetCarritoPartial', function(data) {
                $('#cartBody').html(data);
                $('#cartBadge').text($('#cartItemCount').val() || 0);
            });
        }

        function addToCart(id, titulo, precio, url) {
            $.post('/Carrito/AgregarAjax', { id, titulo, precio, portadaUrl: url }, function(res) {
                if(res.success) {
                    refreshCart();
                    Swal.fire({
                        icon: 'success', title: '¡Agregado!', text: titulo + ' está en tu carrito.',
                        toast: true, position: 'top-end', timer: 2500, showConfirmButton: false
                    });
                }
                else { Swal.fire('Error', res.message, 'error'); }
            });
        }

        function toggleWishlist(id, titulo, precio, url, btnElement) {
            $.post('/Deseos/AlternarAjax', { id: id, titulo: titulo, precio: precio, portadaUrl: url }, function(res) {
                if(res.success) {
                    Swal.fire({
                        icon: res.agregado ? 'success' : 'info',
                        title: res.agregado ? '¡Favorito!' : 'Removido',
                        text: res.message,
                        toast: true, position: 'top-end', timer: 2000, showConfirmButton: false
                    });

                    let icon = $(btnElement).find('i');
                    if(res.agregado) {
                        icon.removeClass('bi-heart').addClass('bi-heart-fill');
                    } else {
                        icon.removeClass('bi-heart-fill').addClass('bi-heart');
                    }
                }
            });
        }

        // Alertas en Español
        $(document).on('submit', '.form-eliminar', function(e) {
            e.preventDefault();
            Swal.fire({ title: '¿Estás seguro?', text: "Esta acción no se puede deshacer.", icon: 'warning', showCancelButton: true, confirmButtonColor: '#d33', confirmButtonText: 'Sí, eliminar', cancelButtonText: 'Cancelar' })
            .then((res) => { if(res.isConfirmed) this.submit(); });
        });

        // --- CHATBOT: MEMORIA Y COLORES ---
        function loadChatHistory() {
            const box = document.getElementById('chatBox');
            if (box) {
                const history = sessionStorage.getItem('chatHistory');
                if (history) {
                    box.innerHTML = history;
                } else {
                    box.innerHTML = `<div class="p-2 mb-2 bg-primary text-white rounded w-75 shadow-sm">¡Hola! ¿En qué puedo ayudarte hoy?</div>`;
                }
                box.scrollTop = box.scrollHeight;
            }
        }

        function handleEnter(e) { if(e.key === 'Enter') sendMsg(); }

        async function sendMsg() {
            const inp = document.getElementById('chatInput');
            const box = document.getElementById('chatBox');
            if(!inp || !inp.value.trim()) return;

            box.innerHTML += `<div class="p-2 mb-2 bg-light text-end ms-auto w-75 rounded border shadow-sm">${inp.value}</div>`;
            const txt = inp.value; inp.value = '';

            sessionStorage.setItem('chatHistory', box.innerHTML);
            box.scrollTop = box.scrollHeight;

            try {
                const res = await fetch(`/Chatbot/Preguntar?mensaje=${encodeURIComponent(txt)}`);
                const data = await res.json();

                let textoDecorado = data.respuesta.replace(/\$([0-9]+(\.[0-9]{1,2})?)/g, '<span class="badge bg-warning text-dark fs-6 ms-1">$$$1</span>');

                box.innerHTML += `<div class="p-2 mb-2 bg-primary text-white rounded w-75 shadow-sm">${textoDecorado}</div>`;
            } catch {
                box.innerHTML += `<div class="p-2 mb-2 bg-danger text-white rounded w-75 shadow-sm">Error de conexión.</div>`;
            }

            sessionStorage.setItem('chatHistory', box.innerHTML);
            box.scrollTop = box.scrollHeight;
        }

        $(document).ready(function() {
            refreshCart();
            loadChatHistory();
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>