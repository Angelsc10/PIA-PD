@{
    ViewData["Title"] = "Panel de Control";
    var alertasStock = ViewBag.AlertasStock as List<PIA_PD.Models.Libro>;
    var topVentas = ViewBag.TopVentas as List<PIA_PD.Controllers.TopVentaDto>;
}

<div class="container mt-5 mb-5">
    <div class="row mb-4">
        <div class="col">
            <h1 class="fw-bold text-dark"><i class="bi bi-speedometer2 me-2 icon-azul"></i>Dashboard Administrativo</h1>
            <p class="text-muted">Resumen financiero y gestión proactiva del Rincón del Libro.</p>
        </div>
    </div>

    <!-- Gráfica de Ingresos  -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4 border-bottom pb-2">
                        <i class="bi bi-graph-up-arrow icon-azul me-2"></i>Ingresos de los últimos 7 días
                    </h5>
                    <div style="position: relative; height:35vh; width:100%">
                        <canvas id="graficaVentas"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-5 g-4">
        <!-- Alertas de Stock Bajo  -->
        <div class="col-md-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header text-white fw-bold py-3" style="background: linear-gradient(135deg, var(--azul-profundo), var(--azul-marino));">
                    <i class="bi bi-exclamation-triangle-fill me-2 icon-oro"></i> Alertas de Stock Bajo
                </div>

                <div class="card-body p-0 alerts-stock-container">
                    @if (alertasStock != null && alertasStock.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var libro in alertasStock)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                                    <div class="d-flex align-items-center">
                                        <img src="@libro.PortadaUrl" style="width: 35px; height: 50px; object-fit: cover;" class="rounded me-3 shadow-sm">
                                        <span class="fw-bold text-dark text-truncate" style="max-width: 250px;">@libro.Titulo</span>
                                    </div>
                                    
                                    <span class="badge rounded-pill px-3 shadow-sm" style="background-color: var(--oro-suave); color: var(--azul-profundo);">
                                        @(libro.Stock == 0 ? "Agotado" : $"Quedan {libro.Stock}")
                                    </span>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-check-circle icon-azul display-4"></i>
                            <p class="mt-3 fw-bold text-muted">Inventario Saludable</p>
                            <p class="small text-muted">Todos los libros tienen stock suficiente.</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Top Ventas  -->
        <div class="col-md-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white fw-bold py-3 border-bottom">
                    <i class="bi bi-trophy-fill me-2 icon-oro"></i> Top 3 Libros Más Vendidos
                </div>
                <div class="card-body p-0">
                    @if (topVentas != null && topVentas.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @{
                                int rank = 1;
                            }
                            @foreach (var venta in topVentas)
                            {
                                string colorMedalla = rank == 1 ? "var(--oro-suave)" : rank == 2 ? "var(--azul-suave)" : "var(--azul-elegante)";
                                <li class="list-group-item d-flex justify-content-between align-items-center py-4 @(rank % 2 == 0 ? "bg-light" : "")">
                                    <div class="d-flex align-items-center">
                                        <h4 class="mb-0 me-3 fw-bold" style="color: @colorMedalla;">#@rank</h4>
                                        <span class="fw-bold text-dark fs-5 text-truncate" style="max-width: 280px;">@venta.Titulo</span>
                                    </div>
                                    <div class="text-end">
                                        <span class="d-block fw-bold icon-azul fs-5">@venta.CantidadVendida</span>
                                        <span class="small text-muted">unidades</span>
                                    </div>
                                </li>
                                rank++;
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-shop icon-gris display-4"></i>
                            <p class="mt-3 fw-bold text-muted">Aún no hay ventas registrados</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Accesos Rápidos -->
    <div class="row g-4">
        @if (User.IsInRole("Admin"))
        {
            <div class="col-md-4">
                <div class="card shadow-sm border-0 h-100 transition-hover" style="background: linear-gradient(135deg, var(--azul-profundo), var(--azul-marino));">
                    <div class="card-body text-center py-4 text-white">
                        <i class="bi bi-people-fill display-4 mb-2 icon-azul"></i>
                        <h4 class="card-title fw-bold">Empleados</h4>
                        <a asp-action="Empleados" class="btn btn-outline-light rounded-pill px-4 mt-2 fw-bold w-100">Gestionar Staff</a>
                    </div>
                </div>
            </div>
        }
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100 transition-hover" style="background: linear-gradient(135deg, var(--azul-elegante), var(--azul-suave));">
                <div class="card-body text-center py-4 text-white">
                    <i class="bi bi-box-seam display-4 mb-2 icon-azul"></i>
                    <h4 class="card-title fw-bold">Inventario Local</h4>
                    <a asp-controller="Inventario" asp-action="Index" class="btn btn-outline-light rounded-pill px-4 mt-2 fw-bold w-100">Ver Bodega</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100 transition-hover" style="background: linear-gradient(135deg, var(--azul-marino), var(--azul-profundo));">
                <div class="card-body text-center py-4 text-white">
                    <i class="bi bi-receipt display-4 mb-2 icon-azul"></i>
                    <h4 class="card-title fw-bold">Historial</h4>
                    <a asp-action="Ventas" class="btn btn-outline-light rounded-pill px-4 mt-2 fw-bold w-100">Consultar Caja</a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .transition-hover:hover {
        transform: translateY(-8px);
        transition: var(--transition);
        box-shadow: var(--shadow-lg) !important;
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            fetch('/Admin/GetDatosVentas')
                .then(response => response.json())
                .then(data => {
                    const etiquetas = data.map(d => d.fecha);
                    const valores = data.map(d => d.total);
                    const ctx = document.getElementById('graficaVentas').getContext('2d');
                    new Chart(ctx, {
                        type: 'line',
                        data: {
                            labels: etiquetas,
                            datasets: [{
                                label: 'Ingresos Diarios ($ MXN)',
                                data: valores,
                                borderColor: '#D4AF37', 
                                backgroundColor: 'rgba(42, 111, 143, 0.1)', 
                                borderWidth: 3,
                                fill: true,
                                tension: 0.4,
                                pointRadius: 5,
                                pointBackgroundColor: '#0B2B40',
                                pointBorderColor: '#D4AF37'
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { labels: { font: { family: 'Inter' } } }
                            },
                            scales: {
                                y: {
                                    beginAtZero: true,
                                    grid: { color: '#EFF3F6' }
                                },
                                x: { grid: { display: false } }
                            }
                        }
                    });
                })
                .catch(error => console.error("Error al cargar la gráfica:", error));
        });
    </script>
}