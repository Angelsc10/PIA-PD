@{
    ViewData["Title"] = "Panel de Control";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col">
            <h1 class="fw-bold"><i class="bi bi-speedometer2 me-2"></i>Panel de Control</h1>
            <p class="text-muted">Bienvenido al sistema de gestión interno.</p>
        </div>
    </div>

    <div class="row g-4">
        @if (User.IsInRole("Admin"))
        {
            <div class="col-md-4">
                <div class="card shadow-sm border-0 bg-primary text-white h-100">
                    <div class="card-body text-center py-5">
                        <i class="bi bi-people-fill display-1 mb-3"></i>
                        <h3 class="card-title fw-bold">Empleados</h3>
                        <p class="card-text">Dar de alta o baja al personal.</p>
                        <button class="btn btn-light rounded-pill px-4 mt-2 fw-bold text-primary">Gestionar</button>
                    </div>
                </div>
            </div>
        }

        <div class="col-md-4">
            <div class="card shadow-sm border-0 bg-success text-white h-100">
                <div class="card-body text-center py-5">
                    <i class="bi bi-box-seam display-1 mb-3"></i>
                    <h3 class="card-title fw-bold">Inventario Local</h3>
                    <p class="card-text">Base de datos de libros físicos.</p>
                    <button class="btn btn-light rounded-pill px-4 mt-2 fw-bold text-success">Ver Stock</button>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 bg-dark text-white h-100">
                <div class="card-body text-center py-5">
                    <i class="bi bi-receipt display-1 mb-3"></i>
                    <h3 class="card-title fw-bold">Historial de Ventas</h3>
                    <p class="card-text">Registro de los tickets generados.</p>
                    <button class="btn btn-light rounded-pill px-4 mt-2 fw-bold text-dark">Consultar</button>
                </div>
            </div>
        </div>
    </div>
</div>