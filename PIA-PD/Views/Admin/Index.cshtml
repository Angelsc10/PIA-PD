@{
    ViewData["Title"] = "Panel de Control";
    // Recibimos la inteligencia de negocios desde el controlador
    var alertasStock = ViewBag.AlertasStock as List<PIA_PD.Models.Libro>;
    var topVentas = ViewBag.TopVentas as List<PIA_PD.Controllers.TopVentaDto>;
}

<div class="container mt-5 mb-5">
    <div class="row mb-4">
        <div class="col">
            <h1 class="fw-bold text-dark"><i class="bi bi-speedometer2 me-2"></i>Dashboard Administrativo</h1>
            <p class="text-muted">Resumen financiero y gestión proactiva del Rincón del Libro.</p>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm border-0 bg-white">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4 border-bottom pb-2">
                        <i class="bi bi-graph-up-arrow text-primary me-2"></i>Ingresos de los últimos 7 días
                    </h5>
                    <div style="position: relative; height:35vh; width:100%">
                        <canvas id="graficaVentas"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-5 g-4">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-danger text-white fw-bold py-3">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> Alertas de Stock Bajo
                </div>
                <div class="card-body p-0">
                    @if (alertasStock != null && alertasStock.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var libro in alertasStock)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                                    <div class="d-flex align-items-center">
                                        <img src="@libro.PortadaUrl" style="width: 35px; height: 50px; object-fit: cover;" class="rounded me-3 shadow-sm">
                                        <span class="fw-bold text-dark text-truncate" style="max-width: 250px;">@libro.Titulo</span>
                                    </div>
                                    <span class="badge @(libro.Stock == 0 ? "bg-dark" : "bg-danger") rounded-pill fs-6 px-3 shadow-sm">
                                        @(libro.Stock == 0 ? "Agotado" : $"Quedan {libro.Stock}")
                                    </span>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-check-circle text-success display-4"></i>
                            <p class="mt-3 fw-bold text-muted">Inventario Saludable</p>
                            <p class="small text-muted">Todos los libros tienen más de 5 unidades.</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-warning text-dark fw-bold py-3">
                    <i class="bi bi-trophy-fill me-2"></i> Top 3 Libros Más Vendidos
                </div>
                <div class="card-body p-0">
                    @if (topVentas != null && topVentas.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @{
                                int rank = 1;
                            }
                            @foreach (var venta in topVentas)
                            {
                                string colorMedalla = rank == 1 ? "gold" : rank == 2 ? "silver" : "#cd7f32"; // Oro, Plata, Bronce
                                                                                                             <li class="list-group-item d-flex justify-content-between align-items-center py-4 bg-light border-bottom">
                                                                                                                 <div class="d-flex align-items-center">
                                                                                                                     <h4 class="mb-0 me-3 fw-bold" style="color: @colorMedalla;">#@rank</h4>
                                                                                                                     <span class="fw-bold text-dark fs-5 text-truncate" style="max-width: 280px;">@venta.Titulo</span>
                                                                                                                 </div>
                                                                                                                 <div class="text-end">
                                                                                                                     <span class="d-block fw-bold text-success fs-5">@venta.CantidadVendida</span>
                                                                                                                     <span class="small text-muted">unidades</span>
                                                                                                                 </div>
                                                                                                             </li>
                                rank++;
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-shop text-muted display-4"></i>
                            <p class="mt-3 fw-bold text-muted">Aún no hay ventas</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        @if (User.IsInRole("Admin"))
        {
            <div class="col-md-4">
                <div class="card shadow-sm border-0 bg-primary text-white h-100 transition-hover">
                    <div class="card-body text-center py-4">
                        <i class="bi bi-people-fill display-4 mb-2"></i>
                        <h4 class="card-title fw-bold">Empleados</h4>
                        <a asp-action="Empleados" class="btn btn-light rounded-pill px-4 mt-2 fw-bold text-primary shadow-sm w-100">Gestionar Staff</a>
                    </div>
                </div>
            </div>
        }
        <div class="col-md-4">
            <div class="card shadow-sm border-0 bg-success text-white h-100 transition-hover">
                <div class="card-body text-center py-4">
                    <i class="bi bi-box-seam display-4 mb-2"></i>
                    <h4 class="card-title fw-bold">Inventario Local</h4>
                    <a asp-controller="Inventario" asp-action="Index" class="btn btn-light rounded-pill px-4 mt-2 fw-bold text-success shadow-sm w-100">Ver Bodega</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-0 bg-dark text-white h-100 transition-hover">
                <div class="card-body text-center py-4">
                    <i class="bi bi-receipt display-4 mb-2"></i>
                    <h4 class="card-title fw-bold">Historial y Excel</h4>
                    <a asp-action="Ventas" class="btn btn-light rounded-pill px-4 mt-2 fw-bold text-dark shadow-sm w-100">Consultar Caja</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            fetch('/Admin/GetDatosVentas')
                .then(response => response.json())
                .then(data => {
                    const etiquetas = data.map(d => d.fecha);
                    const valores = data.map(d => d.total);
                    const ctx = document.getElementById('graficaVentas').getContext('2d');
                    new Chart(ctx, {
                        type: 'line',
                        data: {
                            labels: etiquetas,
                            datasets: [{
                                label: 'Ingresos Diarios ($ MXN)',
                                data: valores,
                                borderColor: '#0d6efd',
                                backgroundColor: 'rgba(13, 110, 253, 0.2)',
                                borderWidth: 3,
                                fill: true,
                                tension: 0.4,
                                pointRadius: 5,
                                pointHoverRadius: 8
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: { legend: { display: true, position: 'top' } },
                            scales: { y: { beginAtZero: true } }
                        }
                    });
                })
                .catch(error => console.error("Error al cargar la gráfica:", error));
        });
    </script>
}