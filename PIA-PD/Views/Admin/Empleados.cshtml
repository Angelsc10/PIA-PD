@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityUser>
@{
    ViewData["Title"] = "Nómina de Staff";
}

<div class="container mt-5 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <h2 class="titulo-elegante mb-0" style="color: var(--azul-profundo);">
            <i class="bi bi-people-fill me-2" style="color: var(--oro-suave);"></i> Recursos Humanos
        </h2>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill shadow-sm">
            <i class="bi bi-arrow-left me-1"></i> Volver al Panel
        </a>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card shadow-md border-0 p-4 bg-white h-100">
                <h4 class="titulo-elegante mb-4" style="color: var(--azul-profundo);">
                    <i class="bi bi-person-plus me-2" style="color: var(--azul-elegante);"></i>Alta de Personal
                </h4>

                <form asp-action="AltaEmpleado" method="post">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted ms-2">Nombre de Usuario</label>
                        <div class="form-floating">
                            <input type="text" name="username" class="form-control shadow-sm" placeholder="Usuario" required>
                            <label>Nombre de Usuario</label>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted ms-2">Contraseña Temporal</label>
                        <div class="form-floating">
                            <input type="password" name="password" class="form-control shadow-sm" placeholder="Pass" required>
                            <label>Contraseña Temporal</label>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2 shadow-sm rounded-pill">
                        <i class="bi bi-person-check me-2"></i>Contratar Empleado
                    </button>
                </form>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-md border-0 h-100 overflow-hidden">
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle text-center">
                        <thead style="background: var(--azul-claro);">
                            <tr>
                                <th class="py-3 titulo-elegante" style="color: var(--azul-profundo); border:none;">Usuario</th>
                                <th class="py-3 titulo-elegante" style="color: var(--azul-profundo); border:none;">Estado</th>
                                <th class="py-3 titulo-elegante" style="color: var(--azul-profundo); border:none;">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Any())
                            {
                                <tr><td colspan="3" class="text-muted py-5">No hay empleados registrados actualmente.</td></tr>
                            }
                            else
                            {
                                @foreach (var emp in Model)
                                {
                                    <tr>
                                        <td class="fw-bold" style="color: var(--azul-marino);">@emp.UserName</td>
                                        <td>
                                            <span class="badge rounded-pill px-3 py-2"
                                                  style="background: var(--azul-claro); color: var(--azul-marino); border: 1px solid var(--azul-suave);">
                                                Activo
                                            </span>
                                        </td>
                                        <td>
                                            <div class="d-flex justify-content-center gap-2">
                                                <a asp-action="EditarEmpleado" asp-route-id="@emp.Id"
                                                   class="btn btn-sm rounded-pill px-3"
                                                   style="border: 1px solid var(--azul-elegante); color: var(--azul-elegante); background: transparent;">
                                                    <i class="bi bi-pencil-square me-1"></i> Editar
                                                </a>

                                                <form asp-action="BajaEmpleado" method="post" class="d-inline">
                                                    <input type="hidden" name="id" value="@emp.Id" />
                                                    <button type="submit" class="btn btn-sm rounded-pill px-3"
                                                            style="border: 1px solid var(--rojo-soft); color: var(--rojo-soft); background: transparent;">
                                                        <i class="bi bi-person-x me-1"></i> Baja
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Estilos de Formulario integrados */
    .form-control {
        border-radius: 48px !important;
        border: 1px solid #DEE2E6;
        transition: var(--transition);
    }

        .form-control:focus {
            border-color: var(--azul-elegante) !important;
            box-shadow: 0 0 0 3px rgba(42, 111, 143, 0.12) !important;
        }

    /* Efecto hover personalizado solicitado para los botones de la tabla */
    .btn-sm {
        transition: var(--transition);
        font-weight: 500;
    }

        .btn-sm:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-sm);
            opacity: 0.85;
        }

    /* Estilo de fila de tabla */
    .table-hover tbody tr:hover {
        background-color: var(--azul-claro);
        transition: var(--transition);
    }
</style>