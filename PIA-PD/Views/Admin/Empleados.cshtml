@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityUser>
@{
    ViewData["Title"] = "Nómina de Staff";
}

<div class="container mt-5">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card shadow border-0 p-4 bg-white h-100">
                <h4 class="fw-bold mb-3"><i class="bi bi-person-plus text-primary me-2"></i>Alta de Personal</h4>
                <form asp-action="AltaEmpleado" method="post">
                    <div class="form-floating mb-3">
                        <input type="text" name="username" class="form-control" placeholder="Usuario" required>
                        <label>Nombre de Usuario</label>
                    </div>
                    <div class="form-floating mb-4">
                        <input type="password" name="password" class="form-control" placeholder="Pass" required>
                        <label>Contraseña Temporal</label>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 rounded-pill shadow-sm">Contratar Empleado</button>
                </form>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow border-0 h-100 overflow-hidden">
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle text-center">
                        <thead class="table-dark">
                            <tr>
                                <th>Usuario</th>
                                <th>Estado</th>
                                <th>Acción</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var emp in Model)
                            {
                                <tr>
                                    <td class="fw-bold">@emp.UserName</td>
                                    <td><span class="badge bg-success rounded-pill px-3">Activo</span></td>
                                    <td>
                                        <form asp-action="BajaEmpleado" method="post" class="form-eliminar">
                                            <input type="hidden" name="id" value="@emp.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                                <i class="bi bi-person-x"></i> Baja
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>