@model List<PIA_PD.Models.Libro>
@{
    ViewData["Title"] = "Catálogo de Libros";
}

<div class="bg-dark text-white py-5 mb-5 shadow-sm" style="background: linear-gradient(45deg, #1a1a1a, #434343);">
    <div class="container text-center">
        <h1 class="display-4 fw-bold">Bienvenido a El Rincón del Libro</h1>
        <p class="lead">Descubre historias increíbles entre nuestro catálogo local y digital.</p>
    </div>
</div>

<div class="container mb-5">
    <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var libro in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0 position-relative transition-hover">

                    @if (libro.Stock <= 0 && !libro.Id.StartsWith("OL"))
                    {
                        <span class="position-absolute top-0 start-0 badge bg-danger m-2 py-2 px-3 shadow" style="z-index: 10;">Agotado</span>
                    }

                    <div class="text-center p-3">
                        <img src="@libro.PortadaUrl" class="card-img-top rounded shadow-sm" alt="@libro.Titulo" style="height: 320px; object-fit: contain; background-color: #f8f9fa;">
                    </div>

                    <div class="card-body d-flex flex-column text-center">
                        <h6 class="card-title fw-bold text-dark mb-1 text-truncate" title="@libro.Titulo">@libro.Titulo</h6>
                        <p class="card-text text-muted small mb-3">@libro.Autor</p>

                        <div class="mt-auto">
                            <h5 class="text-primary fw-bold mb-3">$@libro.Precio.ToString("0.0000") <small class="text-muted fs-6">MXN</small></h5>

                            @if (libro.Stock > 0 || libro.Id.StartsWith("OL"))
                            {
                                <form asp-controller="Carrito" asp-action="Agregar" method="post">
                                    <input type="hidden" name="id" value="@libro.Id" />
                                    <input type="hidden" name="titulo" value="@libro.Titulo" />
                                    <input type="hidden" name="precio" value="@libro.Precio" />
                                    <input type="hidden" name="portadaUrl" value="@libro.PortadaUrl" />
                                    <button type="submit" class="btn btn-primary rounded-pill w-100 shadow-sm">
                                        <i class="bi bi-cart-plus me-2"></i>Agregar al carrito
                                    </button>
                                </form>
                            }
                            else
                            {
                                <button class="btn btn-secondary disabled rounded-pill w-100">
                                    <i class="bi bi-x-circle me-2"></i>No disponible
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .transition-hover:hover {
        transform: translateY(-5px);
        transition: transform 0.3s ease;
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
</style>