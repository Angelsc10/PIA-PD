@model List<PIA_PD.Models.Libro>
@{
    ViewData["Title"] = "Catálogo de Libros";
    string busquedaActual = ViewBag.Busqueda as string;
    string categoriaActual = ViewBag.CategoriaActual as string;
    List<string> categorias = ViewBag.Categorias as List<string> ?? new List<string>();
}

@* Hero Section con tu nueva clase hero-section y bordes dorados *@
<div class="text-white mb-5 shadow-lg hero-section">
    <div class="container text-center">
        <h1 class="display-4 fw-bold mb-3">Busca tu próxima historia</h1>
        <div class="row justify-content-center">
            <div class="col-md-7">
                <form asp-action="Index" method="get" class="input-group input-group-lg shadow-lg">
                    <input type="text" name="q" class="form-control px-4 text-dark" placeholder="Título, autor o palabra clave..." value="@busquedaActual">
                    <button type="submit" class="btn btn-primary px-4 border-0"><i class="bi bi-search fs-5"></i></button>
                </form>
                @if (!string.IsNullOrEmpty(busquedaActual) || !string.IsNullOrEmpty(categoriaActual))
                {
                    <p class="mt-3 text-light" style="text-shadow: 1px 1px 5px rgba(0,0,0,0.8);">
                        Filtro activo: <span class="fw-bold" style="color: var(--oro-suave);">@(busquedaActual ?? categoriaActual)</span>
                        | <a asp-action="Index" class="text-white text-decoration-underline ms-2 small">Quitar filtros</a>
                    </p>
                }
            </div>
        </div>
    </div>
</div>

<div class="container-fluid px-4 px-xl-5 mb-5" style="max-width: 1400px;">
    <div class="row">
        @* Barra Lateral - Adaptada a var(--azul-profundo) *@
        <div class="col-md-4 col-lg-3 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-header text-white py-3 border-0" style="background: linear-gradient(135deg, var(--azul-profundo) 0%, var(--azul-marino) 100%);">
                    <h5 class="mb-0 fw-bold fs-6 text-uppercase" style="letter-spacing: 1px; font-family: 'Inter', sans-serif;">
                        <i class="bi bi-grid-fill me-2 icon-oro"></i> Géneros
                    </h5>
                </div>

                <div class="list-group list-group-flush" style="max-height: 55vh; overflow-y: auto;">
                    <a asp-action="Index" class="list-group-item list-group-item-action border-0 px-4 py-3 @(string.IsNullOrEmpty(categoriaActual) && string.IsNullOrEmpty(busquedaActual) ? "active fw-bold shadow-sm" : "")">
                        Todos / Destacados
                    </a>
                    @foreach (var cat in categorias)
                    {
                        <a asp-action="Index" asp-route-categoria="@cat" class="list-group-item list-group-item-action border-0 px-4 py-3 d-flex justify-content-between align-items-center @(categoriaActual == cat ? "active fw-bold shadow-sm" : "")">
                            <span>
                                <i class="bi bi-chevron-right me-2 @(categoriaActual == cat ? "text-white" : "icon-azul")" style="font-size: 0.8rem;"></i>
                                @cat
                            </span>
                        </a>
                    }
                </div>
            </div>
        </div>

        @* Listado de Libros *@
        <div class="col-md-8 col-lg-9">
            @if (!Model.Any())
            {
                <div class="text-center py-5 bg-white card shadow-sm">
                    <i class="bi bi-emoji-frown display-1 icon-gris"></i>
                    <h3 class="mt-3 text-muted" style="font-family: 'Playfair Display', serif;">No hay libros disponibles.</h3>
                </div>
            }
            else
            {
                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                    @foreach (var libro in Model)
                    {
                        <div class="col">
                            <div class="card h-100 shadow-sm border-0 position-relative transition-hover">

                                @if (User.Identity.IsAuthenticated)
                                {
                                    <div class="position-absolute top-0 end-0 m-2" style="z-index: 10;">
                                        <button type="button" onclick="toggleWishlist('@libro.Id', '@Html.Raw(libro.Titulo.Replace("'", "\\'"))', @libro.Precio.ToString("F2", System.Globalization.CultureInfo.InvariantCulture), '@libro.PortadaUrl', this)" class="btn btn-light rounded-circle shadow p-2 border-0" title="Guardar en Deseos">
                                            <i class="bi @(ViewBag.DeseosIds != null && ((List<string>)ViewBag.DeseosIds).Contains(libro.Id) ? "bi-heart-fill" : "bi-heart icon-azul") fs-5"></i>
                                        </button>
                                    </div>
                                }

                                <div class="text-center p-3">
                                    <img src="@(string.IsNullOrEmpty(libro.PortadaUrl) ? "/img/portadas/default.jpg" : libro.PortadaUrl)"
                                         class="card-img-top rounded shadow-sm"
                                         style="height: 280px; object-fit: contain; background-color: var(--blanco-humo);"
                                         onerror="this.onerror=null; this.src='/img/portadas/default.jpg';">
                                </div>

                                <div class="card-body d-flex flex-column text-center">
                                    <h6 class="card-title fw-bold mb-1 text-truncate" style="color: var(--azul-profundo);" title="@libro.Titulo">@libro.Titulo</h6>
                                    <h6 class="card-text text-muted small mb-3">@libro.Autor</h6>

                                    <div class="mt-auto">
                                        <h5 class="fw-bold mb-3" style="color: var(--azul-elegante); font-family: 'Inter', sans-serif;">$@libro.Precio.ToString("0.00")</h5>

                                        <button type="button"
                                                onclick="addToCart('@libro.Id', '@Html.Raw(libro.Titulo.Replace("'", "\\'"))')"
                                                class="btn btn-primary w-100 shadow-sm">
                                            <i class="bi bi-cart-plus me-2"></i>Añadir al carrito
                                        </button>

                                        <a asp-controller="Home" asp-action="Detalles" asp-route-id="@libro.Id" class="btn btn-volver w-100 mt-2">
                                            <i class="bi bi-star-fill icon-oro me-1"></i> Ver Reseñas
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @* Paginación elegante *@
                @if (ViewBag.TotalPaginas > 1)
                {
                    <nav class="mt-5">
                        <ul class="pagination justify-content-center">
                            @for (int i = 1; i <= ViewBag.TotalPaginas; i++)
                            {
                                <li class="page-item @(i == ViewBag.PaginaActual ? "active" : "")">
                                    <a class="page-link shadow-sm" href="@Url.Action("Index", new { pagina = i, q = ViewBag.Busqueda, categoria = ViewBag.CategoriaActual })">@i</a>
                                </li>
                            }
                        </ul>
                    </nav>
                }
            }
        </div>
    </div>
</div>

<style>
    /* Estilos locales para reforzar la integración con tu CSS externo */
    .list-group-item.active {
        background: linear-gradient(135deg, var(--azul-profundo), var(--azul-marino)) !important;
        border: none !important;
    }

    .page-item.active .page-link {
        background: linear-gradient(135deg, var(--azul-elegante), var(--azul-marino)) !important;
        border: none !important;
    }

    .hero-section h1 {
        font-family: 'Playfair Display', serif;
    }
</style>