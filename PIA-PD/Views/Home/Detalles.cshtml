@model PIA_PD.Models.Libro
@{
    ViewData["Title"] = Model.Titulo;
    var resenas = ViewBag.Resenas as List<PIA_PD.Models.Resena>;
    double promedio = ViewBag.Promedio;
}

<div class="container mt-5 mb-5">
    <div class="row mb-5 bg-white p-4 rounded shadow-sm border">
        <div class="col-md-4 text-center">
            <img src="@Model.PortadaUrl" alt="@Model.Titulo" class="img-fluid rounded shadow" style="max-height: 450px;">

            <div class="mt-4">
                <h3 class="text-primary fw-bold">$@Model.Precio.ToString("0.00") MXN</h3>
                @if (Model.Stock > 0 || Model.Id.StartsWith("OL"))
                {
                    <button type="button"
                            onclick="addToCart('@Model.Id', '@Model.Titulo', @Model.Precio.ToString().Replace(",", "."), '@Model.PortadaUrl')"
                            class="btn btn-primary btn-lg rounded-pill w-100 shadow mt-3">
                        <i class="bi bi-cart-plus me-2"></i>Añadir al Carrito
                    </button>
                }
                else
                {
                    <button class="btn btn-secondary btn-lg disabled rounded-pill w-100 mt-3">Agotado</button>
                }
            </div>
        </div>

        <div class="col-md-8 px-md-5 mt-4 mt-md-0">
            <h1 class="fw-bold">@Model.Titulo</h1>
            <h4 class="text-muted border-bottom pb-3">Por @Model.Autor</h4>

            <div class="d-flex align-items-center mt-3 mb-4">
                <div class="text-warning fs-3 me-2">
                    @for (int i = 1; i <= 5; i++)
                    {
                        if (i <= Math.Round(promedio))
                        {
                            <i class="bi bi-star-fill"></i>
                        }
                        else
                        {
                            <i class="bi bi-star"></i>
                        }
                    }
                </div>
                <span class="fs-4 fw-bold me-2">@promedio.ToString("0.0")</span>
                <span class="text-muted">(Basado en @resenas.Count reseñas)</span>
            </div>

            <p class="lead">Disfruta de esta increíble obra literaria. Añádela a tu carrito y recíbela o descárgala inmediatamente tras tu compra segura.</p>

            <div class="mt-5 p-4 bg-light rounded border">
                <h5 class="fw-bold mb-3"><i class="bi bi-pencil-square me-2"></i>Escribe tu reseña</h5>
                @if (User.Identity.IsAuthenticated)
                {
                    <form asp-action="AgregarResena" method="post">
                        <input type="hidden" name="libroId" value="@Model.Id" />
                        <div class="mb-3">
                            <label class="form-label fw-bold">Calificación:</label>
                            <select name="calificacion" class="form-select w-auto d-inline-block ms-2" required>
                                <option value="5">⭐⭐⭐⭐⭐ Excelente</option>
                                <option value="4">⭐⭐⭐⭐ Muy bueno</option>
                                <option value="3">⭐⭐⭐ Regular</option>
                                <option value="2">⭐⭐ Malo</option>
                                <option value="1">⭐ Pésimo</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <textarea name="comentario" class="form-control" rows="3" placeholder="¿Qué te pareció este libro?..." required></textarea>
                        </div>
                        <button type="submit" class="btn btn-success rounded-pill px-4">Publicar Reseña</button>
                    </form>
                }
                else
                {
                    <div class="alert alert-secondary">
                        <i class="bi bi-info-circle me-2"></i>Debes <a asp-controller="Account" asp-action="Login" class="fw-bold">iniciar sesión</a> para dejar un comentario.
                    </div>
                }
            </div>

            <h5 class="fw-bold mt-5 mb-4">Opiniones de los lectores</h5>
            @if (!resenas.Any())
            {
                <p class="text-muted italic">Aún no hay reseñas. ¡Sé el primero en opinar!</p>
            }
            else
            {
                <div class="list-group">
                    @foreach (var resena in resenas)
                    {
                        <div class="list-group-item list-group-item-action p-3 border-0 shadow-sm mb-2 rounded">
                            <div class="d-flex w-100 justify-content-between">
                                <h6 class="mb-1 fw-bold"><i class="bi bi-person-circle me-2 text-primary"></i>@resena.Usuario</h6>
                                <small class="text-muted">@resena.Fecha.ToString("dd/MM/yyyy")</small>
                            </div>
                            <div class="text-warning small mb-2">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= resena.Calificacion)
                                    {
                                        <i class="bi bi-star-fill"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-star"></i>
                                    }
                                }
                            </div>
                            <p class="mb-1">"@resena.Comentario"</p>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>