@model PIA_PD.Models.Libro
@{
    ViewData["Title"] = "Detalles del Libro";
    var resenas = ViewBag.Resenas as List<PIA_PD.Models.Resena> ?? new List<PIA_PD.Models.Resena>();
    var promedio = ViewBag.Promedio ?? 0.0;
}

<div class="container mt-5 mb-5">
    <div class="row">
        <div class="col-md-4 mb-4 text-center">
            <div class="card shadow-lg border-0 overflow-hidden" style="border-radius: 20px;">
                <img src="@Model.PortadaUrl" class="img-fluid" alt="@Model.Titulo"
                     onerror="this.onerror=null; this.src='https://placehold.co/300x400/0b2b40/ffffff?text=@Uri.EscapeDataString(Model.Titulo)&font=Playfair+Display'"
                     style="width: 100%; height: auto; object-fit: cover; transition: var(--transition);">
            </div>
        </div>
        <div class="col-md-8">
            <h1 class="titulo-elegante display-4 text-dark mb-1">@Model.Titulo</h1>
            <h4 class="text-muted mb-3" style="font-family: 'Inter', sans-serif;">
                Por <span class="icon-azul">@Model.Autor</span>
            </h4>

            <div class="d-flex align-items-center mb-4">
                <span class="badge rounded-pill me-3 shadow-sm py-2 px-3" style="background-color: var(--azul-suave); color: var(--azul-profundo);">
                    @Model.Categoria
                </span>
                <span class="text-warning fs-5 me-2">
                    @for (int i = 1; i <= 5; i++)
                    {
                        if (i <= Math.Round(promedio))
                        {
                            <i class="bi bi-star-fill"></i>
                        }
                        else
                        {
                            <i class="bi bi-star text-muted opacity-25"></i>
                        }
                    }
                </span>
                <span class="text-muted small">(@resenas.Count reseñas)</span>
            </div>

            <h2 class="fw-bold mb-4" style="color: var(--azul-elegante); font-family: 'Inter', sans-serif;">$@Model.Precio.ToString("0.00") <span class="fs-6 text-muted fw-normal">MXN</span></h2>

            @if (Model.Stock > 0)
            {
                <div class="p-4 shadow-sm" style="background-color: var(--gris-sutil); border-radius: 20px;">
                    <p class="fw-bold mb-3" style="color: var(--azul-marino);">
                        <i class="bi bi-check-circle-fill me-2 icon-azul"></i>En inventario: @Model.Stock unidades
                        <span class="text-secondary fw-normal ms-2" style="font-size: 0.9em;">(Has seleccionado <span id="lblSeleccionados">1</span> unidades)</span>
                    </p>
                    <div class="row g-3 align-items-center">
                        <div class="col-auto">
                            <label class="fw-bold text-dark small text-uppercase">Cantidad:</label>
                        </div>
                        <div class="col-auto">
                            <input type="number" id="inputCantidadDetalle" value="1" min="1" max="@Model.Stock" class="form-control text-center shadow-sm" style="width: 85px; border-radius: 40px;" />
                        </div>
                        <div class="col-auto">
                            <button type="button" onclick="addFromDetails('@Model.Id', '@Html.Raw(Model.Titulo.Replace("'", "\\'"))')" class="btn btn-primary px-5 shadow-md">
                                <i class="bi bi-cart-plus me-2"></i>Añadir al Carrito
                            </button>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="alert border-0 rounded-pill px-4 shadow-sm fw-bold" style="background-color: #FDEDEC; color: var(--rojo-soft);">
                    <i class="bi bi-x-circle-fill me-2"></i>Temporalmente agotado
                </div>
            }

            <a asp-action="Index" class="btn btn-volver mt-4 px-4 rounded-pill">
                <i class="bi bi-arrow-left me-2"></i>Regresar al Catálogo
            </a>
        </div>
    </div>

    <div class="row mt-5 pt-4">
        <div class="col-md-12">
            <h3 class="titulo-elegante border-bottom pb-3 mb-4">
                <i class="bi bi-chat-left-text me-2 icon-azul"></i>Experiencias de Lectores
            </h3>

            <div class="row">
                <div class="col-md-5 mb-4">
                    <div class="card border-0 p-4 shadow-sm bg-white" style="border-radius: 20px;">
                        <h5 class="titulo-elegante mb-3" style="font-size: 1.2rem;">Comparte tu opinión</h5>
                        @if (User.Identity.IsAuthenticated)
                        {
                            <form asp-action="AgregarResena" method="post">
                                <input type="hidden" name="libroId" value="@Model.Id" />
                                <div class="mb-3">
                                    <label class="form-label fw-bold small text-muted text-uppercase">Calificación</label>
                                    <select name="calificacion" class="form-select shadow-sm" style="border-radius: 40px;" required>
                                        <option value="5">⭐⭐⭐⭐⭐ Excelente</option>
                                        <option value="4">⭐⭐⭐⭐ Muy bueno</option>
                                        <option value="3">⭐⭐⭐ Regular</option>
                                        <option value="2">⭐⭐ Malo</option>
                                        <option value="1">⭐ Pésimo</option>
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-bold small text-muted text-uppercase">Tu comentario</label>
                                    <textarea name="comentario" class="form-control shadow-sm" rows="3" placeholder="¿Qué te pareció el libro?" style="border-radius: 20px;" required></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary w-100 py-2 shadow-sm">
                                    Publicar reseña
                                </button>
                            </form>
                        }
                        else
                        {
                            <div class="text-center py-4 bg-light rounded-4" style="border-radius: 20px;">
                                <p class="text-muted small mb-3">Inicia sesión para compartir tu experiencia.</p>
                                <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-sm px-4">Iniciar Sesión</a>
                            </div>
                        }
                    </div>
                </div>

                <div class="col-md-7">
                    @if (!resenas.Any())
                    {
                        <div class="text-center py-5 card border-0 bg-light" style="border: 2px dashed #DEE2E6; border-radius: 20px;">
                            <i class="bi bi-chat-square-quote display-4 text-muted opacity-25 mb-3"></i>
                            <h5 class="text-muted">Aún no hay reseñas</h5>
                            <p class="small text-muted mb-0">Sé el primero en compartir qué te pareció este libro.</p>
                        </div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush shadow-sm" style="border-radius: 20px; overflow: hidden;">
                            @foreach (var resena in resenas)
                            {
                                <div class="list-group-item p-4 border-bottom">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <div class="d-flex align-items-center">
                                            <div class="rounded-circle text-white d-flex justify-content-center align-items-center shadow-sm" style="width: 40px; height: 40px; background: linear-gradient(135deg, var(--azul-elegante), var(--azul-marino)); font-weight: bold;">
                                                @(resena.Usuario.Substring(0, 1).ToUpper())
                                            </div>
                                            <div class="ms-3">
                                                <h6 class="mb-0 fw-bold text-dark">@resena.Usuario</h6>
                                                <small class="text-muted" style="font-size: 0.8rem;">@resena.Fecha.ToString("dd/MM/yyyy")</small>
                                            </div>
                                        </div>
                                        <div class="text-warning">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                if (i <= resena.Calificacion)
                                                {
                                                    <i class="bi bi-star-fill"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-star text-muted opacity-25"></i>
                                                }
                                            }
                                        </div>
                                    </div>
                                    <p class="mb-0 mt-3 text-secondary ps-5" style="font-style: italic;">"@resena.Comentario"</p>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('inputCantidadDetalle').addEventListener('input', function (e) {
            let maxStock = parseInt(this.max);
            let valorActual = parseInt(this.value);
            if (valorActual > maxStock) this.value = maxStock;
            if (valorActual < 1) this.value = 1;

            // Actualizar el texto dinámico
            document.getElementById('lblSeleccionados').innerText = this.value || 1;
        });

        function addFromDetails(id, titulo) {
            const cant = document.getElementById('inputCantidadDetalle').value;
            $.post('/Carrito/Agregar', { id: id, cantidad: cant }, function(res) {
                if(res.success) {
                    if(typeof refreshCart === 'function') refreshCart();

                    // Reiniciar el contador de vuelta a 1 tras agregar
                    document.getElementById('inputCantidadDetalle').value = 1;
                    document.getElementById('lblSeleccionados').innerText = 1;

                    Swal.fire({
                        icon: res.alertaStock ? 'info' : 'success',
                        title: res.alertaStock ? 'Límite de stock' : '¡Agregado!',
                        text: res.message || (titulo + ' se añadió al carrito.'),
                        toast: true,
                        position: 'top-end',
                        timer: 2500,
                        showConfirmButton: false
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Lo sentimos',
                        text: res.message,
                        confirmButtonColor: 'var(--azul-elegante)'
                    });
                }
            });
        }
    </script>
}