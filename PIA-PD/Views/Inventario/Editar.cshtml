@model PIA_PD.Models.Libro
@{
    ViewData["Title"] = "Editar Libro";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0 p-4">
                <div class="text-center mb-4 border-bottom pb-3">
                    <h3 class="fw-bold text-primary"><i class="bi bi-pencil-square me-2"></i>Editar Libro</h3>
                </div>

                <form asp-action="Editar" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="Id" />

                    <div class="form-floating mb-3">
                        <input asp-for="Titulo" class="form-control" placeholder="Título" required />
                        <label asp-for="Titulo">Título del Libro *</label>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Autor" class="form-control" placeholder="Autor" required />
                        <label asp-for="Autor">Autor(es) *</label>
                    </div>

                    <div class="form-floating mb-3">
                        <select asp-for="Categoria" class="form-select" required>
                            <option value="Ficción">Ficción</option>
                            <option value="Romance">Romance</option>
                            <option value="Misterio">Misterio</option>
                            <option value="Fantasía">Fantasía</option>
                            <option value="Ciencia Ficción">Ciencia Ficción</option>
                            <option value="Tecnología">Tecnología</option>
                        </select>
                        <label asp-for="Categoria">Categoría Literaria *</label>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Precio" type="number" min="1" step="0.01" class="form-control" placeholder="Precio" required oninput="if(this.value.startsWith('0') || this.value < 0) this.value = '';" />
                                <label asp-for="Precio">Precio MXN *</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Stock" type="number" min="1" class="form-control" placeholder="Stock" required oninput="if(this.value.startsWith('0') || this.value < 0) this.value = '';" />
                                <label asp-for="Stock">Cantidad actual *</label>
                            </div>
                        </div>
                    </div>

                    <div class="p-3 bg-light rounded border mb-4">
                        <h6 class="fw-bold mb-3"><i class="bi bi-image text-primary me-2"></i>Actualizar Portada (Opcional)</h6>

                        <div class="mb-3 text-center">
                            <img src="@Model.PortadaUrl" alt="Portada actual" class="img-thumbnail rounded shadow-sm" style="max-height: 120px;" />
                            <div class="small text-muted mt-1">Portada Actual</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Opción 1: Subir nueva imagen</label>
                            <input type="file" name="imagenPortada" class="form-control" accept="image/*" />
                        </div>

                        <div class="form-floating">
                            <input asp-for="PortadaUrl" class="form-control" placeholder="URL" />
                            <label asp-for="PortadaUrl">Opción 2: Link de internet</label>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Cancelar</a>
                        <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm">Actualizar Libro</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>