@model PIA_PD.Models.Libro
@{
    ViewData["Title"] = "Registro de Libro";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card p-4">
                <div class="text-center mb-4 border-bottom pb-3">
                    <h3 class="fw-bold" style="color: var(--azul-profundo);">
                        <i class="bi bi-journal-plus me-2 icon-azul"></i>Registro de Libro
                    </h3>
                </div>

                <form asp-action="Crear" method="post">
                    <div class="form-floating mb-3">
                        <input asp-for="Titulo" class="form-control" placeholder="Título" required />
                        <label asp-for="Titulo">Título del Libro *</label>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Autor" class="form-control" placeholder="Autor" required />
                        <label asp-for="Autor">Autor(es) *</label>
                    </div>

                    <div class="form-floating mb-3">
                        <select asp-for="Categoria" class="form-select" required>
                            <option value="Ficción">Ficción</option>
                            <option value="Romance">Romance</option>
                            <option value="Misterio">Misterio</option>
                            <option value="Fantasía">Fantasía</option>
                            <option value="Ciencia Ficción">Ciencia Ficción</option>
                            <option value="Tecnología">Tecnología</option>
                        </select>
                        <label asp-for="Categoria">Categoría Literaria *</label>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Precio" type="number" step="0.01" class="form-control" required />
                                <label asp-for="Precio">Precio MXN *</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Stock" type="number" class="form-control" required />
                                <label asp-for="Stock">Cantidad inicial *</label>
                            </div>
                        </div>
                    </div>

                    <div class="p-3 mb-4" style="background: var(--azul-claro); border-radius: 20px;">
                        <h6 class="fw-bold mb-3" style="color: var(--azul-elegante);">
                            <i class="bi bi-image me-2"></i>Imagen de Portada
                        </h6>
                        <div class="form-floating">
                            <input asp-for="PortadaUrl" class="form-control" placeholder="URL de la imagen" />
                            <label asp-for="PortadaUrl">Pega el link de la imagen aquí</label>
                        </div>
                        <div class="form-text mt-2 small text-muted">Ej: https://m.media-amazon.com/images/I/...jpg</div>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-volver px-4">Cancelar</a>

                        <button type="submit" class="btn btn-primary px-4">Guardar Libro</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
