@model PIA_PD.Models.Libro
@{
    ViewData["Title"] = "Agregar Libro Nuevo";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0 p-4">
                <div class="text-center mb-4 border-bottom pb-3">
                    <h3 class="fw-bold text-success"><i class="bi bi-journal-plus me-2"></i>Registrar Libro Físico</h3>
                </div>

                <form asp-action="Crear" method="post" enctype="multipart/form-data">
                    <div class="form-floating mb-3">
                        <input asp-for="Titulo" class="form-control" placeholder="Título" required />
                        <label asp-for="Titulo">Título del Libro *</label>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Autor" class="form-control" placeholder="Autor" required />
                        <label asp-for="Autor">Autor(es) *</label>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Precio" type="number" step="0.01" class="form-control" placeholder="Precio" required />
                                <label asp-for="Precio">Precio MXN *</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Stock" type="number" class="form-control" placeholder="Stock" required />
                                <label asp-for="Stock">Cantidad inicial *</label>
                            </div>
                        </div>
                    </div>

                    <div class="p-3 bg-light rounded border mb-4">
                        <h6 class="fw-bold mb-3"><i class="bi bi-image text-primary me-2"></i>Imagen (Opcional)</h6>
                        <input type="file" name="imagenPortada" class="form-control mb-2" accept="image/*" />
                        <div class="form-floating">
                            <input asp-for="PortadaUrl" class="form-control" placeholder="URL" />
                            <label asp-for="PortadaUrl">O URL de internet</label>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Cancelar</a>
                        <button type="submit" class="btn btn-success rounded-pill px-4 shadow-sm">Guardar Libro</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>