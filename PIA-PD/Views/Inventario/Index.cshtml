@model IEnumerable<PIA_PD.Models.Libro>
@{
    ViewData["Title"] = "Gestión de Stock";
}

<div class="container mt-5 mb-5">
    <div class="card p-4">
        <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
            <h3 class="fw-bold mb-0" style="color: var(--azul-profundo);">
                <i class="bi bi-box-seam icon-azul me-2"></i>Control de Inventario
            </h3>
            <a asp-action="Crear" class="btn btn-primary px-4">
                <i class="bi bi-plus-lg me-2"></i>Registrar Libro
            </a>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 text-center">
                    <thead style="background: var(--azul-claro);">
                        <tr>
                            <th style="color: var(--azul-profundo);">Origen</th>
                            <th style="color: var(--azul-profundo);">Vista</th>
                            <th style="color: var(--azul-profundo);">Título</th>
                            <th style="color: var(--azul-profundo);">Precio</th>
                            <th style="color: var(--azul-profundo);">Stock</th>
                            <th style="color: var(--azul-profundo);">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var libro in Model)
                        {
                            <tr>
                                <td>
                                    @if (libro.Id.StartsWith("OL-"))
                                    {
                                        <span class="badge rounded-pill" style="background: var(--azul-suave); color: white;">
                                            <i class="bi bi-globe me-1"></i> API
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill" style="background: var(--azul-elegante);">
                                            <i class="bi bi-shop me-1"></i> Local
                                        </span>
                                    }
                                </td>
                                <td>
                                    <img src="@libro.PortadaUrl" style="width: 45px; height: 60px; object-fit: cover; border-radius: 8px;" class="shadow-sm">
                                </td>
                                <td class="fw-bold" style="color: var(--azul-profundo);">@libro.Titulo</td>
                                <td class="fw-bold" style="color: var(--azul-elegante);">$@libro.Precio.ToString("0.00")</td>
                                <td>
                                    <span class="badge rounded-pill px-3 py-2" style="background: @(libro.Stock < 5 ? "var(--rojo-soft)" : "var(--azul-profundo)");">
                                        @libro.Stock
                                    </span>
                                </td>
                                <td>
                                    @if (libro.Id.StartsWith("OL-"))
                                    {
                                        <span class="text-muted small"><i class="bi bi-lock-fill"></i> Solo Lectura</span>
                                    }
                                    else
                                    {
                                        <div class="d-flex justify-content-center align-items-center">
                                            <a asp-action="Editar" asp-route-id="@libro.Id"
                                               class="btn btn-sm px-3 me-2"
                                               style="border: 1px solid var(--azul-elegante); color: var(--azul-elegante); border-radius: 40px; transition: var(--transition);">
                                                <i class="bi bi-pencil-square"></i> Editar
                                            </a>

                                            <form asp-action="Eliminar" method="post" class="form-eliminar d-inline">
                                                <input type="hidden" name="id" value="@libro.Id" />
                                                <button type="submit"
                                                        class="btn btn-sm px-3"
                                                        style="border: 1px solid var(--rojo-soft); color: var(--rojo-soft); border-radius: 40px; transition: var(--transition);">
                                                    <i class="bi bi-trash3"></i>
                                                </button>
                                            </form>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>