@model IEnumerable<PIA_PD.Models.Libro>
@{
    ViewData["Title"] = "Inventario Local";
}

<div class="container mt-5 mb-5">

    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success shadow-sm border-0 alert-dismissible fade show mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Exito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger shadow-sm border-0 alert-dismissible fade show mb-4" role="alert">
            <i class="bi bi-exclamation-octagon-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <h2 class="fw-bold text-success"><i class="bi bi-box-seam me-2"></i>Bodega de Libros</h2>
        <div>
            <a asp-action="Crear" class="btn btn-success rounded-pill shadow-sm me-2"><i class="bi bi-plus-lg me-1"></i> Agregar Libro Nuevo</a>
            <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-secondary rounded-pill shadow-sm"><i class="bi bi-arrow-left me-1"></i> Panel</a>
        </div>
    </div>

    <div class="card shadow border-0">
        <div class="card-body p-0 table-responsive">
            <table class="table table-hover mb-0 text-center align-middle">
                <thead class="table-success">
                    <tr>
                        <th>Portada</th>
                        <th>Código (ID)</th>
                        <th>Título</th>
                        <th>Autor</th>
                        <th>Precio Público</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr><td colspan="6" class="text-muted py-5">El inventario físico está vacío. ¡Empieza a agregar libros!</td></tr>
                    }
                    else
                    {
                        foreach (var libro in Model)
                        {
                            <tr>
                                <td>
                                    <img src="@libro.PortadaUrl" alt="Portada" class="img-thumbnail shadow-sm" style="height: 60px; width: 45px; object-fit: cover;">
                                </td>
                                <td class="text-muted small">@libro.Id.Substring(0, 8)...</td>
                                <td class="fw-bold">@libro.Titulo</td>
                                <td>@libro.Autor</td>
                                <td class="text-success fw-bold">$@libro.Precio.ToString("0.00")</td>
                                <td>
                                    <form asp-action="Eliminar" method="post" onsubmit="return confirm('¿Seguro que deseas eliminar este libro del inventario?');">
                                        <input type="hidden" name="id" value="@libro.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>