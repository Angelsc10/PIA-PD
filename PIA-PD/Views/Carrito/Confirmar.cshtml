@model List<PIA_PD.Models.CarritoItem>
@{
    ViewData["Title"] = "Confirmar Compra";
    decimal totalVenta = Model?.Sum(i => i.Precio * i.Cantidad) ?? 0;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0 overflow-hidden">
                <div class="bg-primary text-white p-4 text-center">
                    <h2 class="fw-bold mb-0">Revisa tu Pedido</h2>
                    <p class="mb-0 opactiy-75">Estás a un paso de completar tu compra</p>
                </div>

                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3 border-bottom pb-2">Resumen de Libros</h5>
                    <ul class="list-group list-group-flush mb-4">
                        @foreach (var item in Model)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <div>
                                    <span class="fw-bold">@item.Cantidad x</span> @item.Titulo
                                </div>
                                <span class="text-muted">$@((item.Precio * item.Cantidad).ToString("0.0000"))</span>
                            </li>
                        }
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 fs-4 fw-bold text-primary">
                            <span>Total a pagar:</span>
                            <span>$@totalVenta.ToString("0.0000") MXN</span>
                        </li>
                    </ul>

                    <form asp-action="ProcesarPago" method="post" class="bg-light p-4 rounded border">
                        <h5 class="fw-bold mb-3"><i class="bi bi-envelope-at me-2 text-primary"></i>¿Quieres recibir tu ticket por correo?</h5>
                        <p class="text-muted small mb-3">Ingresa tu email si deseas una copia digital (Opcional).</p>

                        <div class="form-floating mb-4">
                            <input type="email" name="email" class="form-control" id="emailInput" placeholder="nombre@ejemplo.com">
                            <label for="emailInput">Dirección de correo electrónico</label>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg rounded-pill shadow">
                                <i class="bi bi-check-circle me-2"></i>Finalizar Compra y Descargar Ticket
                            </button>
                            <a asp-action="Index" class="btn btn-link text-muted text-decoration-none mt-2">
                                <i class="bi bi-chevron-left"></i> Regresar al carrito
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>