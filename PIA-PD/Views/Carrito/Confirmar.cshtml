@model List<PIA_PD.Models.CarritoItem>
@using PIA_PD.Extensions
@{
    ViewData["Title"] = "Confirmar Compra";
    decimal subtotal = Model?.Sum(i => i.Precio * i.Cantidad) ?? 0;
    var cupon = Context.Session.Get<PIA_PD.Models.Cupon>("MiCupon");
    decimal descuento = cupon != null ? subtotal * (cupon.PorcentajeDescuento / 100m) : 0;
    decimal totalVenta = subtotal - descuento;
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0 overflow-hidden">
                <div class="bg-primary text-white p-4 text-center">
                    <h2 class="fw-bold mb-0"><i class="bi bi-check-circle me-2"></i>Revisa tu Pedido</h2>
                    <p class="mb-0 opacity-75">Estás a un paso de completar tu compra</p>
                </div>

                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3 border-bottom pb-2 text-dark">Resumen de Libros</h5>
                    <ul class="list-group list-group-flush mb-4">
                        @foreach (var item in Model)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0 border-light">
                                <div><span class="badge bg-secondary rounded-pill me-2">@item.Cantidad x</span> <span class="fw-bold">@item.Titulo</span></div>
                                <span class="text-muted">$@((item.Precio * item.Cantidad).ToString("0.00"))</span>
                            </li>
                        }
                    </ul>

                    <div class="bg-light p-3 rounded mb-4">
                        <div class="d-flex justify-content-between mb-2"><span>Subtotal:</span><span class="fw-bold">$@subtotal.ToString("0.00")</span></div>
                        @if (cupon != null)
                        {
                            <div class="d-flex justify-content-between mb-2 text-success"><span>Cupón (@cupon.Codigo):</span><span class="fw-bold">-$@descuento.ToString("0.00")</span></div>
                        }
                        <div class="d-flex justify-content-between align-items-center fs-4 fw-bold text-primary border-top pt-2 mt-2">
                            <span>Total a Pagar:</span><span>$@totalVenta.ToString("0.00") MXN</span>
                        </div>
                    </div>

                    <form asp-action="ProcesarPago" method="post" class="border p-4 rounded bg-white">
                        <h5 class="fw-bold mb-3"><i class="bi bi-envelope-at me-2 text-primary"></i>Ticket Electrónico</h5>
                        <p class="text-muted small mb-3">Ingresa tu email si deseas una copia digital (Opcional).</p>

                        <div class="form-floating mb-4">
                            <input type="email" name="email" class="form-control" id="emailInput" placeholder="nombre@ejemplo.com">
                            <label for="emailInput">Dirección de correo</label>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg rounded-pill shadow">
                                <i class="bi bi-credit-card-fill me-2"></i>Pagar $@totalVenta.ToString("0.00")
                            </button>
                            <a asp-action="Index" class="btn btn-link text-muted text-decoration-none mt-2">
                                <i class="bi bi-chevron-left"></i> Regresar al carrito
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>