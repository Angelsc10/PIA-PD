@model PIA_PD.Models.Venta
@{
    Layout = null; // Esto evita que el Layout intente cargar el CarritoItem y rompa la página
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Comprobante de Orden #@Model.Id</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body {
            background: #e9ecef;
            padding: 20px;
            font-family: 'Segoe UI', sans-serif;
        }

        .ticket-box {
            max-width: 450px;
            margin: auto;
            background: white;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.15);
            overflow: hidden;
        }

        .header-oxxo {
            background: #e11f1c;
            color: white;
            padding: 25px;
            text-align: center;
        }

        .header-success {
            background: #198754;
            color: white;
            padding: 25px;
            text-align: center;
        }

        .barcode-section {
            background: #f8f9fa;
            border: 2px dashed #dee2e6;
            padding: 20px;
            margin: 20px;
            text-align: center;
        }
        @("@") media print {
            .no-print

        {
            display: none !important;
        }

        }
    </style>
</head>
<body>

    <div class="ticket-box">
        @if (Model.MetodoPago == "OXXO")
        {
            <div class="header-oxxo">
                <img src="https://upload.wikimedia.org/wikipedia/commons/6/66/Oxxo_Logo.svg" width="120" class="mb-2">
                <h4 class="fw-bold mb-0">ORDEN DE PAGO EN CAJA</h4>
            </div>
            <div class="p-4">
                <p class="text-center text-muted small">Presenta esta ficha al cajero para completar tu pedido</p>
                <div class="barcode-section">
                    <h6 class="fw-bold text-dark">REFERENCIA DE PAGO</h6>
                    <svg id="barcode"></svg>
                    <div class="mt-2 fw-bold fs-5 text-primary">REF-@Model.Id.ToString("000000")</div>
                </div>
                <div class="text-start mt-3 small text-secondary">
                    <p class="mb-1"><strong>1.</strong> Acude a tu tienda OXXO más cercana.</p>
                    <p class="mb-1"><strong>2.</strong> Indica que realizarás un pago de <strong>OXXO Pay</strong>.</p>
                    <p class="mb-0"><strong>3.</strong> El pago se notificará automáticamente a la librería.</p>
                </div>
            </div>
        }
        else
        {
            <div class="header-success">
                <i class="bi bi-bag-check-fill display-4"></i>
                <h4 class="fw-bold mt-2">¡GRACIAS POR TU COMPRA!</h4>
                <p class="mb-0 small">Tu pedido ha sido procesado con éxito</p>
            </div>
            <div class="p-4">
                <div class="d-flex justify-content-between border-bottom pb-2 mb-2">
                    <span>Folio:</span> <span class="fw-bold">#@Model.Id</span>
                </div>
                <div class="d-flex justify-content-between border-bottom pb-2 mb-3">
                    <span>Método Utilizado:</span> <span class="fw-bold">@Model.MetodoPago</span>
                </div>
                <h6 class="fw-bold mb-2">Resumen de Libros:</h6>
                @foreach (var d in Model.Detalles)
                {
                    <div class="d-flex justify-content-between small text-muted mb-1">
                        <span>@d.Cantidad x @d.Titulo</span>
                        <span>$@((d.PrecioUnitario * d.Cantidad).ToString("0.00"))</span>
                    </div>
                }
            </div>
        }

        <div class="p-4 border-top bg-light text-center">
            <h2 class="fw-bold text-dark mb-0">Total: $@Model.Total.ToString("0.00") MXN</h2>
            <div class="d-grid gap-2 mt-4 no-print">
                <button onclick="window.print()" class="btn btn-dark rounded-pill py-2 fw-bold">
                    <i class="bi bi-file-earmark-pdf me-2"></i>Guardar como PDF / Imprimir
                </button>
                <a href="/" class="btn btn-link text-decoration-none text-secondary">Volver a la Librería</a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"></script>
    <script>
        JsBarcode("#barcode", "LIBRERIA-@Model.Id-OXXO", {
            format: "CODE128",
            width: 2,
            height: 50,
            displayValue: false,
            lineColor: "#212529"
        });
    </script>
</body>
</html>