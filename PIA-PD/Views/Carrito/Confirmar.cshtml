@model PIA_PD.Models.Venta
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Comprobante de Orden #@Model.Id</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" />

    <style>
        body {
            background-color: var(--blanco-humo);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            font-family: 'Inter', sans-serif;
        }

        .ticket-box {
            background: white;
            width: 100%;
            max-width: 450px;
            border-radius: 28px;
            box-shadow: 0 12px 40px rgba(11, 43, 64, 0.12);
            overflow: hidden;
            border: 1px solid rgba(42, 111, 143, 0.1);
        }

        .header-ticket {
            background: linear-gradient(135deg, var(--azul-profundo), var(--azul-marino));
            color: white;
            padding: 35px 25px;
            text-align: center;
        }

        .header-oxxo-white {
            background: white;
            padding: 30px;
            text-align: center;
            border-bottom: 4px solid #e11f1c;
        }

        .barcode-section {
            background: var(--azul-claro);
            border: 2px dashed var(--azul-elegante);
            border-radius: 20px;
            padding: 25px;
            margin: 20px;
            text-align: center;
        }

        .item-row {
            border-bottom: 1px solid var(--azul-claro);
            padding: 10px 0;
        }

        .btn-print {
            background: linear-gradient(135deg, var(--azul-elegante), var(--azul-marino));
            border: none;
            border-radius: 40px;
            padding: 12px;
        }

        @@media print {
            .no-print {
                display: none !important;
            }

            .ticket-box {
                box-shadow: none;
                border: 1px solid #eee;
            }
        }
    </style>
</head>
<body>

    <div class="ticket-box">
        @if (Model.MetodoPago == "OXXO")
        {
            <div class="header-oxxo-white">
                <img src="https://upload.wikimedia.org/wikipedia/commons/6/66/Oxxo_Logo.svg" width="130" class="mb-3">
                <h4 class="mb-0 text-dark">ORDEN DE PAGO</h4>
                <p class="text-muted small mb-0">OXXO Pay™</p>
            </div>

            <div class="p-4">
                <p class="text-center text-muted small">Presenta esta ficha al cajero para completar tu pedido</p>

                <div class="barcode-section">
                    <h6 class="text-dark mb-3">REFERENCIA DE PAGO</h6>
                    <svg id="barcode" style="width: 100%; max-width: 250px; height: auto;"></svg>
                    <div class="mt-2 fw-bold fs-5" style="color: var(--azul-profundo);">REF-@Model.Id.ToString("000000")</div>
                </div>

                <div class="text-start mt-3 small text-secondary px-2">
                    <p class="mb-1"><i class="bi bi-info-circle-fill me-2 icon-azul"></i> Indica al cajero que es un pago de <strong>OXXO Pay</strong>.</p>
                    <p class="mb-0"><i class="bi bi-clock-history me-2 icon-azul"></i> El pago se refleja de forma inmediata.</p>
                </div>
            </div>
        }
        else
        {
            <div class="header-ticket">
                <i class="bi bi-check2-circle display-4 mb-2 icon-oro"></i>
                <h4 class="mb-0">¡GRACIAS POR TU COMPRA!</h4>
                <p class="mb-0 small opacity-75">Tu pedido ha sido procesado</p>
            </div>

            <div class="p-4">
                <div class="d-flex justify-content-between mb-4">
                    <span class="text-muted small">Folio: #@Model.Id</span>
                    <span class="badge rounded-pill" style="background-color: var(--azul-claro); color: var(--azul-elegante);">@Model.MetodoPago</span>
                </div>

                <h6 class="mb-3 border-bottom pb-2">Resumen:</h6>
                @foreach (var d in Model.Detalles)
                {
                    <div class="d-flex justify-content-between small item-row">
                        <span>@d.Cantidad x @d.Titulo</span>
                        <span class="fw-bold">$@((d.PrecioUnitario * d.Cantidad).ToString("0.00"))</span>
                    </div>
                }
            </div>
        }

        <div class="p-4 border-top bg-light">
            <div class="d-flex justify-content-between fs-4 fw-bold mb-4" style="color: var(--azul-profundo);">
                <span>TOTAL:</span>
                <span>$@Model.Total.ToString("0.00") <small class="fs-6">MXN</small></span>
            </div>

            <div class="d-grid gap-2 no-print">
                <button class="btn btn-print text-white fw-bold shadow-sm" onclick="window.print()">
                    <i class="bi bi-printer me-2"></i> Imprimir o Guardar PDF
                </button>
                <a href="/Home/Index" class="btn btn-light rounded-pill fw-bold border text-muted">
                    <i class="bi bi-house me-2"></i> Volver al Inicio
                </a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.0/dist/JsBarcode.all.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            if (document.getElementById("barcode")) {
                JsBarcode("#barcode", "7501" + "00" + "@Model.Id.ToString("00000")", {
                    format: "CODE128",
                    lineColor: "#000",
                    width: 2,
                    height: 50,
                    displayValue: false
                });
            }
        });
    </script>
</body>
</html>