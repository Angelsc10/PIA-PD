@model List<PIA_PD.Models.CarritoItem>
@{
    ViewData["Title"] = "Mi Carrito";
    decimal totalVenta = Model?.Sum(i => i.Precio * i.Cantidad) ?? 0;
}

<div class="container mt-5">
    <h2 class="fw-bold mb-4"><i class="bi bi-cart-check me-2"></i>Tu Carrito de Compras</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-cart-x display-1 text-muted"></i>
            <p class="fs-4 mt-3">Tu carrito está vacío.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary rounded-pill px-4">Ir a buscar libros</a>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-lg-8">
                @foreach (var item in Model)
                {
                    <div class="card mb-3 shadow-sm border-0">
                        <div class="row g-0 align-items-center">
                            <div class="col-md-2 text-center p-2">
                                <img src="@item.PortadaUrl" class="img-fluid rounded" alt="@item.Titulo" style="max-height: 120px;">
                            </div>
                            <div class="col-md-6">
                                <div class="card-body">
                                    <h5 class="card-title fw-bold">@item.Titulo</h5>
                                    <p class="text-success fw-bold mb-0">$@item.Precio.ToString("0.00") MXN</p>
                                </div>
                            </div>
                            <div class="col-md-2 text-center">
                                <span class="badge bg-light text-dark border p-2">Cant: @item.Cantidad</span>
                            </div>
                            <div class="col-md-2 text-center">
                                <a asp-action="Eliminar" asp-route-id="@item.LibroId" class="btn btn-link text-danger" title="Eliminar">
                                    <i class="bi bi-trash3 fs-5"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="col-lg-4">
                <div class="card shadow border-0 p-4 bg-light">
                    <h4 class="fw-bold border-bottom pb-3">Resumen</h4>
                    <div class="d-flex justify-content-between fs-5 mb-3">
                        <span>Subtotal:</span>
                        <span>$@totalVenta.ToString("0.00")</span>
                    </div>
                    <div class="d-flex justify-content-between fs-4 fw-bold mb-4">
                        <span>Total:</span>
                        <span class="text-primary">$@totalVenta.ToString("0.00")</span>
                    </div>

                    <form asp-controller="Carrito" asp-action="ProcesarPago" method="post">
                        <button type="submit" class="btn btn-success btn-lg w-100 rounded-pill mb-3 shadow">
                            <i class="bi bi-credit-card me-2"></i>Proceder al Pago
                        </button>
                    </form>

                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary w-100 rounded-pill">Seguir comprando</a>
                </div>
            </div>
        </div>
    }
</div>