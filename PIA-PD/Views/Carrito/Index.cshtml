@model IEnumerable<PIA_PD.Models.CarritoItem>

@{
    ViewData["Title"] = "Carrito de Compras";
}

<h2 class="my-4 text-success"><i class="fas fa-shopping-cart"></i> Tu Carrito</h2>

<!-- AQUÍ SE MOSTRARÁN LOS ERRORES DE STOCK (Añadido nuevo) -->
@if (TempData["ErrorStock"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <strong>¡Atención!</strong> @TempData["ErrorStock"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info text-center py-4">
        <h4>Tu carrito está vacío.</h4>
        <p>¡Explora nuestros libros y encuentra tu próxima aventura!</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-success mt-3">Ir a la Tienda</a>
    </div>
}
else
{
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle">
            <thead class="bg-success text-white">
                <tr>
                    <th>Libro</th>
                    <th>Precio</th>
                    <th style="width: 150px;">Cantidad</th>
                    <th>Subtotal</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>@item.Titulo</strong></td>
                        <td>@item.Precio.ToString("C")</td>
                        <td>
                            <form asp-action="ActualizarCantidad" method="post" class="d-flex">
                                <input type="hidden" name="id" value="@item.LibroId" />
                                <!-- AQUÍ EMPIEZA EL CAMBIO: min="1" -->
                                <input type="number" name="cantidad" value="@item.Cantidad" min="1" class="form-control form-control-sm me-2" onchange="this.form.submit()" />
                            </form>
                        </td>
                        <td class="font-weight-bold text-success">@((item.Precio * item.Cantidad).ToString("C"))</td>
                        <td>
                            <form asp-action="Eliminar" method="post">
                                <input type="hidden" name="id" value="@item.LibroId" />
                                <button type="submit" class="btn btn-danger btn-sm shadow-sm">
                                    <i class="fas fa-trash-alt"></i> Eliminar
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-end align-items-center mt-4 p-3 bg-light rounded shadow-sm border">
        <h4 class="mb-0 me-4">Total: <span class="text-success font-weight-bold">@Model.Sum(i => i.Precio * i.Cantidad).ToString("C")</span></h4>
        <a asp-action="Checkout" class="btn btn-primary btn-lg shadow-sm">
            <i class="fas fa-check-circle"></i> Proceder al Pago
        </a>
    </div>
}