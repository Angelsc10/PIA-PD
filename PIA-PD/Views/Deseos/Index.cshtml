@model IEnumerable<PIA_PD.Models.Deseo>
@{
    ViewData["Title"] = "Mi Lista de Deseos";
}

<div class="container mt-5 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <h2 class="fw-bold text-danger"><i class="bi bi-heart-fill me-2"></i>Mi Lista de Deseos</h2>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary rounded-pill shadow-sm"><i class="bi bi-arrow-left me-1"></i> Seguir Explorando</a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-light rounded shadow-sm border">
            <i class="bi bi-heartbreak display-1 text-muted mb-3"></i>
            <h3 class="fw-bold text-dark">Tu lista está vacía</h3>
            <p class="text-muted">Guarda los libros que más te gusten presionando el corazón en el catálogo.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-danger rounded-pill px-4 mt-2">Ir a buscar historias</a>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
            @foreach (var deseo in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 position-relative transition-hover">

                        <div class="position-absolute top-0 end-0 m-2" style="z-index: 10;">
                            <form asp-action="Eliminar" method="post" class="form-eliminar">
                                <input type="hidden" name="id" value="@deseo.Id" />
                                <button type="submit" class="btn btn-light rounded-circle shadow-sm text-danger p-2" title="Quitar de la lista">
                                    <i class="bi bi-trash-fill"></i>
                                </button>
                            </form>
                        </div>

                        <div class="text-center p-3">
                            <img src="@deseo.PortadaUrl" class="card-img-top rounded shadow-sm" style="height: 280px; object-fit: contain; background-color: #f8f9fa;">
                        </div>
                        <div class="card-body d-flex flex-column text-center">
                            <h6 class="card-title fw-bold text-dark mb-1 text-truncate" title="@deseo.Titulo">@deseo.Titulo</h6>
                            <p class="text-muted small">Agregado el @deseo.FechaAgregado.ToString("dd/MM/yyyy")</p>

                            <div class="mt-auto">
                                <h5 class="text-primary fw-bold mb-3">$@deseo.Precio.ToString("0.00")</h5>

                                <form asp-controller="Carrito" asp-action="Agregar" method="post">
                                    <input type="hidden" name="id" value="@deseo.LibroId" />
                                    <input type="hidden" name="titulo" value="@deseo.Titulo" />
                                    <input type="hidden" name="precio" value="@deseo.Precio" />
                                    <input type="hidden" name="portadaUrl" value="@deseo.PortadaUrl" />
                                    <button type="submit" class="btn btn-success rounded-pill w-100 shadow-sm">
                                        <i class="bi bi-cart-plus me-2"></i>Pasar al Carrito
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .transition-hover:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        transition: all 0.3s;
    }
</style>