@model IEnumerable<PIA_PD.Models.Deseo>
@{
    ViewData["Title"] = "Mi Lista de Deseos";
}

<div class="container mt-5 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <h2 class="titulo-elegante text-dark m-0">
            <i class="bi bi-heart-fill me-2 icon-oro"></i>Mi Lista de Deseos
        </h2>
        <a asp-controller="Home" asp-action="Index" class="btn btn-volver rounded-pill shadow-sm">
            <i class="bi bi-arrow-left me-1"></i> Explorar más
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 card border-0 bg-light">
            <i class="bi bi-heartbreak display-1 icon-gris opacity-50 mb-3"></i>
            <h3 class="titulo-elegante text-muted">Tu lista está vacía</h3>
            <p class="text-muted">Guarda tus historias favoritas para leerlas después.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
            @foreach (var deseo in Model)
            {
                <div class="col">
                    <div class="card h-100 position-relative">
                        
                        <div class="position-absolute top-0 end-0 m-2" style="z-index: 10;">
                            <form asp-action="Eliminar" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@deseo.Id" />
                                <button type="submit" class="btn-eliminar-discreto" title="Quitar de la lista">
                                    <i class="bi bi-x-lg no-scale"></i>
                                </button>
                            </form>
                        </div>

                        <div class="text-center p-3">
                            <img src="@deseo.PortadaUrl" class="img-fluid rounded shadow-sm" 
                                 style="height: 220px; object-fit: contain; background: var(--gris-sutil);">
                        </div>

                        <div class="card-body d-flex flex-column text-center pt-0">
                            <h6 class="card-title text-dark mb-1 text-truncate">@deseo.Titulo</h6>
                            <p class="small text-muted mb-3">Agregado el @deseo.FechaAgregado.ToString("dd/MM")</p>

                            <div class="mt-auto">
                                <h5 class="fw-bold mb-3 icon-azul">$@deseo.Precio.ToString("0.00")</h5>

                                <form asp-controller="Carrito" asp-action="Agregar" method="post">
                                    <input type="hidden" name="id" value="@deseo.LibroId" />
                                    <input type="hidden" name="titulo" value="@deseo.Titulo" />
                                    <input type="hidden" name="precio" value="@deseo.Precio" />
                                    <input type="hidden" name="portadaUrl" value="@deseo.PortadaUrl" />
                                    <button type="submit" class="btn btn-primary w-100 py-2">
                                        <i class="bi bi-cart-plus me-1"></i> Comprar
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    /* Estilo único para el botón de cerrar que no interfiere con tus botones globales */
    .btn-eliminar-discreto {
        background: rgba(255, 255, 255, 0.9);
        border: none;
        color: var(--rojo-soft);
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.8rem;
        box-shadow: var(--shadow-sm);
        transition: var(--transition);
        backdrop-filter: blur(4px);
    }

    .btn-eliminar-discreto:hover {
        background: var(--rojo-soft);
        color: white;
        transform: rotate(90deg) scale(1.1);
    }

    /* Ajuste fino para las imágenes en la lista de deseos */
    .card img {
        transition: transform 0.4s ease;
    }

    .card:hover img {
        transform: scale(1.05);
    }
</style>